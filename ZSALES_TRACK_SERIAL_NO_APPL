*---------------------------------------------------------------------*
* double_click_document
*---------------------------------------------------------------------*
  METHOD double_click_document.
  DATA: wa_sales_track_sn TYPE s_sales_track_sn.

    READ TABLE _t_sales_track_sn INTO wa_sales_track_sn INDEX row.
    IF ( sy-subrc = 0 ).
      CASE column.
      WHEN 'VBELN_VA' OR 'POSNR_VA'.
        SET PARAMETER ID 'AUN' FIELD wa_sales_track_sn-vbeln_va.
        SET PARAMETER ID 'VPO' FIELD wa_sales_track_sn-posnr_va.
        CALL TRANSACTION 'VA03' AND SKIP FIRST SCREEN.
      WHEN 'VBELN_VF' OR 'POSNR_VF'.
        SET PARAMETER ID 'VF' FIELD wa_sales_track_sn-vbeln_vf.
        SET PARAMETER ID 'VFP' FIELD wa_sales_track_sn-posnr_vf.
        CALL TRANSACTION 'VF03' AND SKIP FIRST SCREEN.
      WHEN OTHERS.
        MESSAGE 'Position cursor on Billing or Sales Document column' TYPE 'I'.
      ENDCASE.
    ENDIF.

  ENDMETHOD.

ENDCLASS.
