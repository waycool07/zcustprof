*---------------------------------------------------------------------*
*       FORM LIKP_LESEN                                               *
*---------------------------------------------------------------------*
*       Lieferungen    werden gelesen und in die interne Arbeitstab   *
*       abgelegt                                                      *
*---------------------------------------------------------------------*
FORM LIKP_LESEN.

* Füllen Selektionstabelle für die Belege.
* Es werden nur die gefundenen Lieferungen berücksichtigt
  LOOP AT XVBUK WHERE VBOBJ = LIEFERUNG.
    XVBELN-LOW = XVBUK-VBELN.
    XVBELN-SIGN = 'I'.
    XVBELN-OPTION = 'EQ'.
    APPEND XVBELN.
  ENDLOOP.
  CHECK SY-SUBRC = 0.

* Belegkoepfe werden im 100-Block gelesen.
  DO.
    PERFORM YVBELN_FUELLEN.

* Lesen Lieferungen.
    SELECT * FROM LIKP APPENDING TABLE XLIKP WHERE VBELN IN YVBELN
                                             AND   KKBER IN KKBER
                                             AND   KNKLI IN KNKLI
                                             AND   GRUPP IN GRUPP
                                             AND   SBGRP IN SBGRP
                                             AND   CTLPC IN CTLPC
                                             AND   CMNGV IN CMNGV
                                             AND   VKORG IN VKORG "CCARD
                                             AND   VKBUR IN VKBUR "CCARD
                                             AND   ERNAM IN ERNAM "CCARD
*                                            and   rplnr in rplnr "CCARD
                                             ORDER BY PRIMARY KEY.
* Check that the previous document has payment cards
    IF CARDMODE = 'X'.                 "CCard
      TABLES: LIPS.
      DATA: DELETE_FLAG.
      LOOP AT XLIKP.
        DELETE_FLAG = 'X'.
        SELECT * FROM LIPS
               WHERE VBELN = XLIKP-VBELN.
          IF NOT LIPS-VGBEL IS INITIAL AND
             NOT LIPS-ABFOR IS INITIAL.
            SELECT SINGLE * FROM VBAK
                   WHERE VBELN = LIPS-VGBEL
                   AND   RPLNR IN RPLNR.
            IF SY-SUBRC = 0.
              DELETE_FLAG = ' '.
              EXIT.
            ENDIF.
          ENDIF.
        ENDSELECT.
        IF DELETE_FLAG = 'X'.
          DELETE XLIKP.
        ENDIF.
      ENDLOOP.
    ENDIF.
* Sind keine Belege mehr vorggeben, wird die Selektionsschleife
* verlassen.
    DESCRIBE TABLE XVBELN LINES SY-TFILL.
    IF SY-TFILL = 0.
      EXIT.
    ENDIF.
  ENDDO.
ENDFORM.                    "LIKP_LESEN

*---------------------------------------------------------------------*
*       FORM MATCHCODE_LESEN                                          *
*---------------------------------------------------------------------*
*       Bei Eingabe des Matchcodes werden die Belege                  *
*       über den Matchcode selektiert                                 *
*       Das Ermitteln der Belege ist  in der dazugehörigen            *
*       Formroutine ( Name = Matchcodetabelle ) hinterlegt            *
*---------------------------------------------------------------------*
*  -->  MATCHCODE                                                     *
*  -->  ID                                                            *
*---------------------------------------------------------------------*
FORM MATCHCODE_LESEN USING MATCHCODE ID.
  DATA: POOL LIKE DD20V-POOL.

  POOL   = 'M'.
  POOL+1 = MATCHCODE.
  POOL+5 = '_'.
  POOL+6 = ID.
  PERFORM (POOL) IN PROGRAM SAPDBKMV.

ENDFORM.                    "MATCHCODE_LESEN

*---------------------------------------------------------------------*
*       FORM ORT_ERMITTELN                                            *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
*  -->  KUNDE                                                         *
*  -->  ADRESSE                                                       *
*  -->  NAME                                                          *
*  -->  ORT                                                           *
*  -->  VBADR                                                         *
*---------------------------------------------------------------------*
FORM ORT_ERMITTELN USING US_KUNDE ADRESSE NAME ORT LAND.
  DATA: RC LIKE SY-SUBRC.

  READ TABLE KUNDE WITH KEY KNKLI = US_KUNDE
                            ADRNR = ADRESSE
                            BINARY SEARCH.
  RC = SY-SUBRC.
  IF SY-SUBRC = 0.
    NAME = KUNDE-NAME1.
    ORT  = KUNDE-ORT01.
    LAND = KUNDE-LAND.
  ELSE.
    VBPA-KUNNR = US_KUNDE.
    VBPA-ADRNR = ADRESSE.
    CALL FUNCTION 'VIEW_VBADR'
      EXPORTING
        INPUT   = VBPA
        NRART   = 'KU'
      IMPORTING
        ADRESSE = VBADR.
    NAME         = VBADR-NAME1.
    ORT          = VBADR-ORT01.
    LAND         = VBADR-LAND1.
    KUNDE-KNKLI = US_KUNDE.
    KUNDE-NAME1 = NAME.
    KUNDE-ORT01 = ORT.
    KUNDE-LAND  = LAND.
    KUNDE-ADRNR = ADRESSE.
    IF RC = 8 OR SY-TABIX = 0.
      APPEND KUNDE.
    ELSE.
      INSERT KUNDE INDEX SY-TABIX.
    ENDIF.
  ENDIF.
ENDFORM.                    "ORT_ERMITTELN

*---------------------------------------------------------------------*
*       FORM VBAK_LESEN                                               *
*---------------------------------------------------------------------*
*       Verkaufsbelege werden gelesen und in die interne Arbeitstab   *
*       abgelegt                                                      *
*---------------------------------------------------------------------*
FORM VBAK_LESEN.
  DATA: TABLE_SIZE LIKE SY-TFILL.

  REFRESH XVBELN.

* Füllen Selektionstabelle für die Belege.
* Es werden nur die gefundenen Aufträge berücksichtigt
  LOOP AT XVBUK WHERE VBOBJ = VERKAUFSBELEG.
    XVBELN-LOW = XVBUK-VBELN.
    XVBELN-SIGN = 'I'.
    XVBELN-OPTION = 'EQ'.
    APPEND XVBELN.
  ENDLOOP.

  CHECK SY-SUBRC = 0.

* Belegkoepfe werden im 100-Block gelesen.
  DO.
    PERFORM YVBELN_FUELLEN.

* Lesen Verkaufsbelege
    SELECT * FROM VBAK APPENDING TABLE XVBAK WHERE VBELN IN YVBELN
                                             AND   KKBER IN KKBER
                                             AND   KNKLI IN KNKLI
                                             AND   GRUPP IN GRUPP
                                             AND   SBGRP IN SBGRP
                                             AND   CTLPC IN CTLPC
                                             AND   CMNGV IN CMNGV
                                             AND   CMNUP IN CMNUP
                                             AND   VKBUR IN VKBUR "CCard
                                             AND   VKGRP IN VKGRP "CCard
                                             AND   VKORG IN VKORG "CCARD
                                             AND   VTWEG IN VTWEG "CCARD
                                             AND   SPART IN SPART "CCARD
                                             AND   ERNAM IN ERNAM "CCard
                                             AND   RPLNR IN RPLNR "CCard
                                             ORDER BY PRIMARY KEY.

* Sind keine Belege mehr vorggeben, wird die Selektionsschleife
* verlassen.
    DESCRIBE TABLE XVBELN LINES SY-TFILL.
    IF SY-TFILL = 0.
      EXIT.
    ENDIF.
  ENDDO.
ENDFORM.                    "VBAK_LESEN

*---------------------------------------------------------------------*
*       FORM FPLA_LESEN                                               *
*---------------------------------------------------------------------*
*       Zahlungskarten werden gelesen und in die interne Arbeitstab   *
*       abgelegt (FPLA)                                               *
*---------------------------------------------------------------------*
FORM FPLA_LESEN.
* CCARD - Begin
  TABLES: FPLA.
  DATA: BEGIN OF RPLNR_TAB OCCURS 10,
          RPLNR LIKE VBAK-RPLNR,
        END OF RPLNR_TAB.

  CHECK CARDMODE = 'X'.

  LOOP AT XVBAK.
    CHECK NOT XVBAK-RPLNR IS INITIAL.
    RPLNR_TAB-RPLNR = XVBAK-RPLNR.
    APPEND RPLNR_TAB.
  ENDLOOP.

  DESCRIBE TABLE RPLNR_TAB LINES SY-TFILL.
  CHECK SY-TFILL NE 0.

  SORT RPLNR_TAB.
  SELECT * FROM FPLA APPENDING TABLE XFPLA FOR ALL ENTRIES IN RPLNR_TAB
           WHERE FPLNR = RPLNR_TAB-RPLNR
           AND   AUST1 IN AUST1
           AND   AUST2 IN AUST2
           AND   AUST3 IN AUST3
           AND   AUST5 IN AUST5
           ORDER BY PRIMARY KEY.

  LOOP AT XVBAK.
    CHECK NOT XVBAK-RPLNR IS INITIAL.
    READ TABLE XFPLA
         WITH KEY FPLNR = XVBAK-RPLNR
         BINARY SEARCH.
    IF SY-SUBRC NE 0.
      DELETE XVBAK.
    ENDIF.
  ENDLOOP.
* CCARD - End
ENDFORM.                    "FPLA_LESEN

*---------------------------------------------------------------------*
*       FORM VBAP_LESEN                                               *
*---------------------------------------------------------------------*
*       Positionen     werden gelesen und in die interne Arbeitstab   *
*       abgelegt                                                      *
*       Die Positionen werden gelesen, um die nächste Einteilung      *
*       zur Ermittlung der des frühesten Versanddatum zu erhalten     *
*---------------------------------------------------------------------*
FORM VBAP_LESEN.

  REFRESH XVBELN.

* Füllen Selektionstabelle für die Belege
  LOOP AT XVBAK.
    MOVE-CORRESPONDING XVBAK TO BELEG_KEY.
    READ TABLE XVBUK WITH KEY BELEG_KEY BINARY SEARCH.
    CHECK SY-SUBRC EQ 0.
    XVBELN-LOW = XVBAK-VBELN.
    XVBELN-SIGN = 'I'.
    XVBELN-OPTION = 'EQ'.
    APPEND XVBELN.
  ENDLOOP.
  CHECK SY-SUBRC = 0.

  DESCRIBE TABLE XVBELN LINES SY-TFILL.
  CHECK SY-TFILL GT 0.

* Belegkoepfe werden im 100-Block gelesen.
  DO.
    PERFORM YVBELN_FUELLEN.
* Lesen Positionen
    SELECT * FROM VBAP APPENDING TABLE XVBAP WHERE VBELN IN YVBELN
                                             AND   CMPNT = 'X'
                                             ORDER BY PRIMARY KEY.

* Sind keine Belege mehr vorggeben, wird die Selektionsschleife
* verlassen.
    DESCRIBE TABLE XVBELN LINES SY-TFILL.
    IF SY-TFILL = 0.
      EXIT.
    ENDIF.
  ENDDO.
ENDFORM.                    "VBAP_LESEN

*---------------------------------------------------------------------*
*       FORM VBEP_LESEN                                               *
*---------------------------------------------------------------------*
*       Einteilungen werden gelesen und in die interne Arbeitstab     *
*       abgelegt.                                                     *
*       Ermittlung des frühesten Versanddatums interne Arbeitstab     *
*---------------------------------------------------------------------*
FORM VBEP_LESEN USING BELEG.
  SELECT * FROM VBEP APPENDING TABLE XVBEP WHERE VBELN = BELEG
                                           ORDER BY PRIMARY KEY.

  SELECT * FROM VBUP APPENDING TABLE XVBUP  WHERE VBELN = BELEG
                                       ORDER BY PRIMARY KEY.

  SELECT * FROM VBFA APPENDING TABLE XVBFA  WHERE VBELV = BELEG
                                       ORDER BY PRIMARY KEY.

ENDFORM.                    "VBEP_LESEN


*----------------------------------------------------------------------*
*       FORM VBPA_LESEN
*----------------------------------------------------------------------*
*       Partner 'Auftraggeber lesen'
*----------------------------------------------------------------------*
FORM VBPA_LESEN.
  RANGES PARVW FOR VBPA-PARVW.
  MOVE: 'I' TO PARVW-SIGN,
        'EQ' TO PARVW-OPTION,
