FORM CREDIT_RESCHEDULING_GET_DB USING US_VBELN US_TYP.
* US_TYP: A order, L = delivery
* this routine gets all open order and delivery credit values of all
* documents (orders) which are rechecked
  IF US_TYP = 'A'.
    REFRESH MCINF. CLEAR MCINF.
    MOVE 'S066'  TO MCINF-LOW.
    MOVE 'I'     TO MCINF-SIGN.
    MOVE 'EQ'    TO MCINF-OPTION.
    APPEND MCINF.

    CLEAR DVBUK.
    REFRESH DVBUK.
    CLEAR DVBUP.
    REFRESH DVBUP.
    CLEAR DVBAK.
    REFRESH DVBAK.
    CLEAR DVBAP.
    REFRESH DVBAP.
    CLEAR DVBEP.
    REFRESH DVBEP.
    CLEAR DVBPA.
    REFRESH DVBPA.
    REFRESH DVBFA.
    CLEAR DVBAPF.
    REFRESH DVBAPF.
    CLEAR DVBKD.
    REFRESH DVBKD.

    LOOP AT XVBAK WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBAK TO: DVBAK, EVBAK.
      APPEND DVBAK.
      APPEND EVBAK.
    ENDLOOP.

    LOOP AT XVBUK WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBUK TO DVBUK.
      DVBUK-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBUK.
    ENDLOOP.

    LOOP AT XVBUP WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBUP TO DVBUP.
      DVBUP-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBUP.
    ENDLOOP.

    LOOP AT XVBAP WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBAP TO DVBAP.
      DVBAP-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBAP.
    ENDLOOP.

    LOOP AT XVBEP WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBEP TO DVBEP.
      DVBEP-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBEP.
    ENDLOOP.

    LOOP AT XVBFA INTO DVBFA WHERE VBELV EQ US_VBELN.
      DVBFA-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBFA.
    ENDLOOP.

    LOOP AT XVBAPF WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBAPF TO DVBAPF.
      APPEND DVBAPF.
    ENDLOOP.

    LOOP AT XVBKD WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBKD TO DVBKD.
      DVBKD-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBKD.
    ENDLOOP.

    MCCONTROL-SPROG = 'SAPLVKMP'.
    CLEAR MCCONTROL-SROUT.
    MCCONTROL-SROUT = 'DBL_'.
    CALL FUNCTION 'MCV_STATISTICS_ORDER'
      EXPORTING
        TRTYP       = 'V'
        XVBAK       = DVBAK
        YVBAK       = EVBAK
        XVBAK_UPDKZ = CON_UPDKZ_INSERT
        YVBAK_UPDKZ = SPACE
        MODUS       = CON_MODUS_SIM  "Simulation
        SPROG       = MCCONTROL-SPROG
        SROUT       = MCCONTROL-SROUT
        POSITION    = SPACE
      TABLES
        XKOMV       = DKOMV
        XVBAP       = DVBAP
        XVBEP       = DVBEP
        XVBKD       = DVBKD
        XVBPA       = DVBPA
        XVBFA       = DVBFA
        XVBUK       = DVBUK
        XVBUP       = DVBUP
        YVBAP       = EVBAP
        YVBEP       = EVBEP
        YVBKD       = EVBKD
        YVBPA       = EVBPA
        YVBFA       = EVBFA
        YVBUK       = EVBUK
        YVBUP       = EVBUP
        VBAPF       = DVBAPF
        MCINF       = MCINF.
  ELSE.
    CLEAR DLIKP.
    REFRESH DLIKP.
    CLEAR DLIPS.
    REFRESH DLIPS.
    CLEAR DVBUK.
    REFRESH DVBUK.
    CLEAR DVBUP.
    REFRESH DVBUP.
    CLEAR DVBAK.
    REFRESH DVBAK.
    CLEAR DVBAP.
    CLEAR DVBAP.
    REFRESH DVBAP.
    CLEAR DVBPA.
    REFRESH DVBPA.
    REFRESH DVBFA.

    LOOP AT XLIKP WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XLIKP TO: DLIKP, LIKP.
      APPEND DLIKP.
    ENDLOOP.

    LOOP AT XVBUK WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBUK TO DVBUK.
      DVBUK-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBUK.
    ENDLOOP.

    LOOP AT XVBUP WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING XVBUP TO DVBUP.
      DVBUP-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBUP.
    ENDLOOP.

    LOOP AT LLIPS WHERE VBELN EQ US_VBELN.
      MOVE-CORRESPONDING LLIPS TO DLIPS.
      DLIPS-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DLIPS.
    ENDLOOP.

    LOOP AT XVBFA INTO DVBFA WHERE VBELV EQ US_VBELN.
      DVBFA-UPDKZ = CON_UPDKZ_INSERT.
      APPEND DVBFA.
    ENDLOOP.

    MOVE 'S067'  TO MCINF-LOW.
    MOVE 'I'     TO MCINF-SIGN.
    MOVE 'EQ'    TO MCINF-OPTION.
    APPEND MCINF.

    MCCONTROL-SPROG = 'SAPLVKMP'.
    CLEAR MCCONTROL-SROUT.
    MCCONTROL-SROUT = 'DBL_'.
    CALL FUNCTION 'MCV_STATISTICS_DELIVERY'
      EXPORTING
        LIKP        = LIKP
        TRTYP       = 'V'
        YLIKP       = LIKP
        YLIKP_UPDKZ = ' '
        MODUS       = CON_MODUS_SIM  "Simulation
        SPROG       = MCCONTROL-SPROG
        SROUT       = MCCONTROL-SROUT
      TABLES
        XLIKP       = DLIKP
        XVBUK       = DVBUK
        XVBPA       = DVBPA
        YVBUK       = EVBUK
        YVBPA       = EVBPA
        XLIPS       = DLIPS
        XVBUP       = DVBUP
        XVBFA       = DVBFA
        YLIPS       = ELIPS
        YVBUP       = EVBUP
        YVBFA       = EVBFA
        XVBAK       = EVBAK
        XVBAP       = EVBAP
        MCINF       = MCINF.
  ENDIF.
*
  PERFORM SET_VBELN_INTO_DB_S066(SAPLVKMP) USING US_VBELN US_TYP.
ENDFORM.                    "CREDIT_RESCHEDULING_GET_DB

*---------------------------------------------------------------------*
*       FORM VBAK_ODER_VBUK                                           *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
*  -->  CH_TABELLE                                                    *
*---------------------------------------------------------------------*
FORM VBAK_ODER_VBUK CHANGING CH_TABELLE.
  DATA: SAV_LINES_KKBER LIKE SY-TABIX,
        SAV_LINES_KNKLI LIKE SY-TABIX,
        SAV_LINES_CTLPC LIKE SY-TABIX,
        SAV_LINES_SBGRP LIKE SY-TABIX,
        SAV_LINES_GRUPP LIKE SY-TABIX,
        SAV_LINES_VBELN LIKE SY-TABIX,
        SAV_LINES_CMGST LIKE SY-TABIX,
        SAV_LINES_GBSTK LIKE SY-TABIX,
        SAV_LINES_CMNGV LIKE SY-TABIX,
        SAV_LINES_CMNUP LIKE SY-TABIX.
  DATA: CMGST_A_FLAG.

  DESCRIBE TABLE KKBER LINES SAV_LINES_KKBER.
  DESCRIBE TABLE KNKLI LINES SAV_LINES_KNKLI.
  DESCRIBE TABLE CTLPC LINES SAV_LINES_CTLPC.
  DESCRIBE TABLE SBGRP LINES SAV_LINES_SBGRP.
  DESCRIBE TABLE GRUPP LINES SAV_LINES_GRUPP.
  DESCRIBE TABLE VBELN LINES SAV_LINES_VBELN.
  DESCRIBE TABLE CMGST LINES SAV_LINES_CMGST.
  DESCRIBE TABLE GBSTK LINES SAV_LINES_GBSTK.
  DESCRIBE TABLE CMNGV LINES SAV_LINES_CMNGV.
  DESCRIBE TABLE CMNUP LINES SAV_LINES_CMNUP.


* Zugriff über Matchcode ?
* Bedingungen und VBELN
* Kreditstatus CMGST nicht 'A' und nicht ' '
  IF 'A' IN CMGST.
    CMGST_A_FLAG = 'X'.
  ENDIF.
  IF ' ' IN CMGST.
    CMGST_A_FLAG = 'X'.
  ENDIF.
* Beleggesamtstatus GBSTK nicht ' ' und nicht 'C'
  IF ' ' IN GBSTK.
    CMGST_A_FLAG = 'X'.
  ENDIF.
  IF 'C' IN GBSTK.
    CMGST_A_FLAG = 'X'.
  ENDIF.
  DESCRIBE TABLE VBELN LINES SAV_LINES_VBELN.
  IF SAV_LINES_VBELN = 0 AND CMGST_A_FLAG IS INITIAL.
    MOVE CON_MACO TO CH_TABELLE.
    EXIT.
  ENDIF.

* Zugriff über VBUK ?
* CMGST oder GBSTK oder VBELN, alle anderen INITIAL
  IF SAV_LINES_KKBER IS INITIAL AND
     SAV_LINES_KNKLI IS INITIAL AND
     SAV_LINES_CTLPC IS INITIAL AND
     SAV_LINES_SBGRP IS INITIAL AND
     SAV_LINES_GRUPP IS INITIAL AND
     SAV_LINES_CMNGV IS INITIAL AND
     SAV_LINES_CMNUP IS INITIAL AND
     ( NOT SAV_LINES_CMGST IS INITIAL OR
       NOT SAV_LINES_GBSTK IS INITIAL OR
       NOT SAV_LINES_VBELN IS INITIAL ).
    MOVE CON_VBUK TO CH_TABELLE.
    EXIT.
  ENDIF.

* Zugriff über VBAK/LIKP ?
* ansonsten
  MOVE CON_VBAK TO CH_TABELLE.
ENDFORM.                    "VBAK_ODER_VBUK

*---------------------------------------------------------------------*
*       FORM VBAK_LESEN_VOR_VBUK                                      *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
FORM VBAK_LESEN_VOR_VBUK.
  IF NOT ( ORDER IS INITIAL ).
*   Lesen Verkaufsbelege
    SELECT * FROM VBAK APPENDING TABLE XVBAK
      WHERE VBELN IN VBELN
      AND   KKBER IN KKBER
      AND   KNKLI IN KNKLI
      AND   GRUPP IN GRUPP
      AND   SBGRP IN SBGRP
      AND   CTLPC IN CTLPC
      AND   CMNGV IN CMNGV
      AND   CMNUP IN CMNUP
      AND   VKBUR IN VKBUR             "CCard
      AND   VKGRP IN VKGRP             "CCard
      AND   VKORG IN VKORG             "CCard
      AND   VTWEG IN VTWEG             "CCard
      AND   SPART IN SPART             "CCard
      AND   ERNAM IN ERNAM             "CCard
      AND   RPLNR IN RPLNR             "CCard
      ORDER BY PRIMARY KEY.
  ENDIF.
ENDFORM.                    "VBAK_LESEN_VOR_VBUK

*---------------------------------------------------------------------*
*       FORM LIKP_LESEN_VOR_VBUK                                      *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
FORM LIKP_LESEN_VOR_VBUK.
  IF NOT ( DELIV IS INITIAL ).
*   Lesen Lieferbelege
    SELECT * FROM LIKP APPENDING TABLE XLIKP
      WHERE VBELN IN VBELN
      AND   KKBER IN KKBER
      AND   KNKLI IN KNKLI
      AND   GRUPP IN GRUPP
      AND   SBGRP IN SBGRP
      AND   CTLPC IN CTLPC
      AND   CMNGV IN CMNGV
      AND   VKORG IN VKORG             "CCard
      AND   VKBUR IN VKBUR             "CCard
      AND   ERNAM IN ERNAM             "CCard
*     and   rplnr in rplnr                "CCard
      AND   VBTYP NOT IN ('7', 'g')
      ORDER BY PRIMARY KEY.
* Check that the previous document has payment cards
    IF CARDMODE = 'X'.                 "CCard
    DATA: DELETE_FLAG.
      LOOP AT XLIKP.
        DELETE_FLAG = 'X'.
        SELECT * FROM LIPS
               WHERE VBELN = XLIKP-VBELN.
          IF NOT LIPS-VGBEL IS INITIAL AND
             NOT LIPS-ABFOR IS INITIAL.
            SELECT SINGLE * FROM VBAK
                   WHERE VBELN = LIPS-VGBEL
                   AND   RPLNR IN RPLNR.
            IF SY-SUBRC = 0.
              DELETE_FLAG = ' '.
              EXIT.
            ENDIF.
          ENDIF.
         ENDSELECT.
         IF DELETE_FLAG = 'X'.
          DELETE XLIKP.
        ENDIF.
    ENDLOOP.
  ENDIF.
  ENDIF.
ENDFORM.                    "LIKP_LESEN_VOR_VBUK

*---------------------------------------------------------------------*
*       FORM VBUK_LESEN_NACH_VBAK                                     *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
FORM VBUK_LESEN_NACH_VBAK.
  DATA: TABLE_SIZE LIKE SY-TFILL.

  REFRESH XVBELN.

* Füllen Selektionstabelle für die Belege.
  LOOP AT XVBAK.
    XVBELN-LOW = XVBAK-VBELN.
    XVBELN-SIGN = 'I'.
    XVBELN-OPTION = 'EQ'.
    APPEND XVBELN.
  ENDLOOP.
  LOOP AT XLIKP.
    XVBELN-LOW = XLIKP-VBELN.
    XVBELN-SIGN = 'I'.
    XVBELN-OPTION = 'EQ'.
    APPEND XVBELN.
  ENDLOOP.

  DESCRIBE TABLE XVBELN LINES SY-TABIX.
  CHECK SY-TABIX GT 0.
  SORT XVBELN.

* Belegkoepfe werden im 100-Block gelesen.
  DO.
    PERFORM YVBELN_FUELLEN.

*   Lesen VBUK
    SELECT * FROM VBUK APPENDING TABLE XVBUK WHERE VBELN IN YVBELN
                                             AND   CMGST IN CMGST
                                             AND   GBSTK IN GBSTK
        ORDER BY PRIMARY KEY.

*   Sind keine Belege mehr vorggeben, wird die Selektionsschleife
*   verlassen.
    DESCRIBE TABLE XVBELN LINES SY-TFILL.
    IF SY-TFILL = 0.
      EXIT.
    ENDIF.
  ENDDO.
ENDFORM.                    "VBUK_LESEN_NACH_VBAK

