*---------------------------------------------------------------------*
*       FORM VBKRED_FUELLEN                                           *
*---------------------------------------------------------------------*
*       Arbeitstabelle für Kreditlimit wird über Verkaufsbelge        *
*       Lieferungen und Belegkoepfe gefuellt                          *
*---------------------------------------------------------------------*
FORM VBKRED_FUELLEN.

  DATA: DA_DUMMY_LAND LIKE VBKRED-LAND.

* Übertragen Informationen aus gefundenen Aufträgen
  LOOP AT XVBAK.
    CLEAR XVBKRED.
    MOVE-CORRESPONDING XVBAK TO BELEG_KEY.
    READ TABLE XVBUK WITH KEY BELEG_KEY BINARY SEARCH.
    CHECK SY-SUBRC EQ 0.
* Allgemeiner Belegkopf
    MOVE-CORRESPONDING XVBUK TO XVBKRED.
* Auftragskopf
    MOVE-CORRESPONDING XVBAK TO XVBKRED.
    XVBKRED-KUNAG = XVBAK-KUNNR.
    IF NOT XVBAK-RPLNR IS INITIAL.
      READ TABLE XFPLA WITH KEY FPLNR = XVBAK-RPLNR BINARY SEARCH.
      MOVE-CORRESPONDING XFPLA TO XVBKRED.
      MOVE XVBAK-VBELN         TO XVBKRED-VBELN.
    ENDIF.
* Auftragsposition.
    PERFORM VBEP_LESEN USING BELEG_KEY-VBELN.
    CALL FUNCTION 'SD_CREDIT_VALUE_ORDER'
      EXPORTING
        VBAK   = XVBAK
      IMPORTING
        AMTBL  = XVBKRED-KWKKB
        KWKKG  = XVBKRED-KWKKF
      TABLES
        XVBAP  = XVBAP
        XVBAPF = XVBAPF
        XVBFA  = XVBFA
        XVBKD  = XVBKD
        XVBUP  = XVBUP.
    MOVE XVBKRED-KWKKB TO XVBKRED-KWKKC.
    MOVE XVBKRED-KWKKF TO XVBKRED-KWKKG.
* Ermitteln Versanddatum
    IF XVBKRED-CMNGV IS INITIAL.
      CALL FUNCTION 'SD_NEXT_ACTION_DATE_ORDER'
        EXPORTING
          XVBAK = XVBAK
        IMPORTING
          CMNGV = XVBKRED-CMNGV
        TABLES
          XVBAP = XVBAP
          XVBEP = XVBEP
          XVBFA = XVBFA
          XVBUK = XVBUK
          XVBUP = XVBUP.
    ENDIF.
*   Ermitteln Partnerdaten
    READ TABLE XVBPA WITH KEY VBELN = XVBAK-VBELN
                              PARVW = 'RG'
                      BINARY SEARCH.
    IF SY-SUBRC = 0 AND
       NOT ( XVBPA-ADRNR IS INITIAL ).
      IF XVBKRED-KNKLI = XVBPA-KUNNR.  "Kreditkonto = Regulierer
        XVBKRED-ADRNR = XVBPA-ADRNR.
      ELSE.
        CLEAR XVBKRED-ADRNR.
      ENDIF.
    ELSE.
      CLEAR XVBKRED-ADRNR.
    ENDIF.

    IF NOT XVBKRED-KNKLI IS INITIAL.
      PERFORM ORT_ERMITTELN USING XVBKRED-KNKLI XVBKRED-ADRNR
                                  XVBKRED-NAME1 XVBKRED-ORT01
                                  XVBKRED-LAND.
    ENDIF.
    IF NOT XVBKRED-KUNAG IS INITIAL.
      PERFORM ORT_ERMITTELN USING XVBKRED-KUNAG XVBKRED-AGADRNR
                                  XVBKRED-AGNAME1 XVBKRED-AGORT01
                                  DA_DUMMY_LAND.
    ENDIF.
    PERFORM ZAHLUNGSBEDINGUNGEN_ERMITTELN USING XVBKRED-VBELN
                                                XVBKRED-POSNR
                                                XVBKRED-ZTERM.
    MOVE XVBKD-LCNUM TO XVBKRED-LCNUM.
    PERFORM STATUS_ERMITTELN.
    PERFORM CC_STATUS_ERMITTELN.       "CCARD
    PERFORM CREDIT_EXPOSURE.
*   MOVE-CORRESPODING aus VBAK/LIKP läuft vor KNKK
    XVBKRED-ERNAM = XVBAK-ERNAM.
    XVBKRED-ERDAT = XVBAK-ERDAT.
    XVBKRED-GRUPP = XVBAK-GRUPP.
    XVBKRED-SBGRP = XVBAK-SBGRP.
    XVBKRED-CTLPC = XVBAK-CTLPC.
    IF TVAK-AUART NE XVBAK-AUART.
      SELECT SINGLE * FROM TVAK WHERE AUART EQ XVBAK-AUART.
    ENDIF.
    XVBKRED-CRMGR = TVAK-CMGRA.
    IF    T691F-KKBER NE XVBAK-KKBER
    OR    T691F-CTLPC NE XVBAK-CTLPC
    OR    T691F-CRMGR NE TVAK-CMGRA.
      CLEAR T691F.
      SELECT SINGLE * FROM T691F
      WHERE KKBER EQ XVBAK-KKBER
      AND   CTLPC EQ XVBAK-CTLPC
      AND   CRMGR EQ TVAK-CMGRA.
    ENDIF.
    XVBKRED-TAGEF = T691F-TAGEF.
    PERFORM AUTHORITY_CHECK_DOCUMENT CHANGING XVBKRED
                                              AUTH_VBUK_RC.
    PERFORM AUTHORITY_CHECK_CUSTOMER CHANGING XVBKRED
                                              AUTH_KNKK_RC.
    CHECK AUTH_VBUK_RC EQ 0
    AND   AUTH_KNKK_RC EQ 0.
    APPEND XVBKRED.
  ENDLOOP.

* Übertragen Informationen aus gefundenen Lieferungen
  LOOP AT XLIKP.
    CLEAR XVBKRED.
    MOVE-CORRESPONDING XLIKP TO BELEG_KEY.
    READ TABLE XVBUK WITH KEY BELEG_KEY BINARY SEARCH.
    CHECK SY-SUBRC EQ 0.
    MOVE-CORRESPONDING XVBUK TO XVBKRED.
    MOVE-CORRESPONDING XLIKP TO XVBKRED.
*
    REFRESH: LVBAK, LVBAP, LVBKD.
    CALL FUNCTION 'SD_CREDIT_VALUE_DELIVERY'
      EXPORTING
        LIKP  = XLIKP
      IMPORTING
        AMTBL = XVBKRED-KWKKB
        KWKKG = XVBKRED-KWKKF                               "n_712183
      TABLES
        LVBAK = LVBAK
        LVBAP = LVBAP
        XLIPS = LLIPS
        XVBUP = XVBUP                                       "K11K101476
        XVBKD = LVBKD.
    MOVE XVBKRED-KWKKB TO XVBKRED-KWKKC.
    MOVE XVBKRED-KWKKF TO XVBKRED-KWKKG.                    "n_712183
*
    CALL FUNCTION 'SD_NEXT_ACTION_DATE_DELIVERY'
      EXPORTING
        LIKP   = XLIKP
      IMPORTING
        LCMNGV = XVBKRED-CMNGV
      TABLES
        XVBUK  = XVBUK.
    READ TABLE XVBPA WITH KEY VBELN = XLIKP-VBELN
                              PARVW = 'RG'
                      BINARY SEARCH.
    IF SY-SUBRC = 0 AND
       NOT ( XVBPA-ADRNR IS INITIAL ).
      IF XVBKRED-KNKLI = XVBPA-KUNNR.  "Kreditkonto = Regulierer
        XVBKRED-ADRNR = XVBPA-ADRNR.
      ELSE.
        CLEAR XVBKRED-ADRNR.
      ENDIF.
    ELSE.
      READ TABLE XVBPA WITH KEY VBELN = XLIKP-VBELN
                                PARVW = 'AG'
                        BINARY SEARCH.
      IF XVBKRED-KNKLI = XVBPA-KUNNR.  "Kreditkonto = Auftraggeber
        XVBKRED-ADRNR = XVBPA-ADRNR.
      ELSE.
        CLEAR XVBKRED-ADRNR.
      ENDIF.
    ENDIF.

    IF NOT XVBKRED-KNKLI IS INITIAL.
      PERFORM ORT_ERMITTELN USING XVBKRED-KNKLI XVBKRED-ADRNR
                                  XVBKRED-NAME1 XVBKRED-ORT01
                                  XVBKRED-LAND.
    ENDIF.
    IF NOT XVBKRED-KUNAG IS INITIAL.
      PERFORM ORT_ERMITTELN USING XVBKRED-KUNAG XVBKRED-AGADRNR
                                  XVBKRED-AGNAME1 XVBKRED-AGORT01
                                  DA_DUMMY_LAND.
    ENDIF.

    PERFORM STATUS_ERMITTELN.
    PERFORM CREDIT_EXPOSURE.
    XVBKRED-CMNGV = XLIKP-WADAT.
    XVBKRED-ERNAM = XLIKP-ERNAM.
    XVBKRED-ERDAT = XLIKP-ERDAT.
    XVBKRED-GRUPP = XLIKP-GRUPP.
    XVBKRED-SBGRP = XLIKP-SBGRP.
    XVBKRED-CTLPC = XLIKP-CTLPC.
    CLEAR  XVBKRED-ZTERM.
    IF TVLK-LFART NE XLIKP-LFART.
      SELECT SINGLE * FROM TVLK WHERE LFART EQ XLIKP-LFART.
    ENDIF.
    XVBKRED-CRMGR = TVLK-CMGRL.
    IF    T691F-KKBER NE XLIKP-KKBER
    OR    T691F-CTLPC NE XLIKP-CTLPC
    OR    T691F-CRMGR NE TVLK-CMGRL.
      CLEAR T691F.
      SELECT SINGLE * FROM T691F
      WHERE KKBER EQ XLIKP-KKBER
      AND   CTLPC EQ XLIKP-CTLPC
      AND   CRMGR EQ TVLK-CMGRL.
    ENDIF.
    XVBKRED-TAGEF = T691F-TAGEF.
    PERFORM AUTHORITY_CHECK_DOCUMENT CHANGING XVBKRED
                                              AUTH_VBUK_RC.
    PERFORM AUTHORITY_CHECK_CUSTOMER CHANGING XVBKRED
                                              AUTH_KNKK_RC.
    CHECK AUTH_VBUK_RC EQ 0
    AND   AUTH_KNKK_RC EQ 0.
    APPEND XVBKRED.
  ENDLOOP.

* Übertragen Infos aus Kundenmodifikation
  PERFORM USER_EXIT_FUELLEN_XVBKRED.
ENDFORM.                    "VBKRED_FUELLEN

*---------------------------------------------------------------------*
*       FORM VBKREDET_FUELLEN                                         *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
*  -->  CH_KWKKD                                                      *
*  -->  CH_KWKKE                                                      *
*---------------------------------------------------------------------*
FORM VBKREDET_FUELLEN CHANGING CH_KWKKD CH_KWKKE.           "P30K028860
  LOCAL: XVBAPF-REMNG, XVBAPF-ERLMENGE_F.
  DATA: DA_DUMMY LIKE VBKREDET-KWKKF.
  DATA: DA_SUM_KBMENG LIKE VBAP-KBMENG.
  DATA: OLFMNG_Q15 TYPE MC_OLIMEAU.
  CLEAR: CH_KWKKD, CH_KWKKE.
* Detaildaten aus Position und Einteilung füllen
  REFRESH XVBKREDET. CLEAR: XVBKREDET, VBKREDET.
  IF VBKRED-VBTYP CA VBTYP_VERK.
*   Ermitteln Kreditfortschreibung
    READ TABLE XVBAK WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN BINARY SEARCH.
    READ TABLE XVBUK WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN BINARY SEARCH.
    IF NOT XVBUK-CMPSB IS INITIAL.
*     Horizont ermitteln
      IF TVAK-AUART NE XVBAK-AUART.
        SELECT SINGLE * FROM TVAK WHERE AUART EQ XVBAK-AUART.
      ENDIF.
      IF    T691F-KKBER NE XVBAK-KKBER
      OR    T691F-CTLPC NE XVBAK-CTLPC
      OR    T691F-CRMGR NE TVAK-CMGRA.
        CLEAR T691F.
        SELECT SINGLE * FROM T691F
        WHERE KKBER EQ XVBAK-KKBER
        AND   CTLPC EQ XVBAK-CTLPC
        AND   CRMGR EQ TVAK-CMGRA.
        IF NOT T691F-WSWIN IS INITIAL.
          PERFORM HORIZON_DATE(SAPLVKMP)
            USING    'S066'
                     T691F-WSWIN
            CHANGING SAV_HORIZON.
          PERFORM GET_LAST_DATE_OF_PERIOD(SAPLVKMP)
            USING    SAV_HORIZON XVBAK-KKBER
            CHANGING SAV_HORIZON SAV_DATE_FIRST.
        ELSE.
          SAV_HORIZON = '99991231'.
        ENDIF.
      ENDIF.
    ENDIF.
    PERFORM TVKO_READ(SAPLVKMP) USING    XVBAK-VKORG
                                CHANGING SAV_BUKRS.
    IF T001-BUKRS NE SAV_BUKRS.
      SELECT SINGLE * FROM T001
      WHERE BUKRS EQ SAV_BUKRS.
    ENDIF.
    READ TABLE XVBKD WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN
                              POSNR = '000000'     BINARY SEARCH.
    READ TABLE XVBAP WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN BINARY SEARCH.
    LOOP AT XVBAP FROM SY-TABIX.
      IF XVBAP-VBELN NE XVBAK-VBELN. EXIT. ENDIF.
      READ TABLE XVBKD WITH KEY MANDT = SY-MANDT
                                VBELN = VBKRED-VBELN
                                POSNR = XVBAP-POSNR  BINARY SEARCH.
      READ TABLE XVBUP WITH KEY MANDT = SY-MANDT
                                VBELN = VBKRED-VBELN
                                POSNR = XVBAP-POSNR  BINARY SEARCH.
      CHECK XVBUP-GBSTA CA 'AB'.
*     Anzeige, nur wenn Position noch nicht erledigt.
      PERFORM KREDIT_AKTIV(SAPLMCSB)
      USING     SPACE
                XVBAK
                XVBAP
                DLIKP
                LLIPS
                VBRKVB
                VBRPVB
      CHANGING  CREDIT_STAFO
                CREDIT_PERIV.
      IF NOT CREDIT_STAFO IS INITIAL.
        CLEAR XVBEP.
        READ TABLE XVBEP WITH KEY MANDT = SY-MANDT
                                  VBELN = XVBAP-VBELN
                                  POSNR = XVBAP-POSNR  BINARY SEARCH.
        SAV_TABIX = SY-TABIX.
        IF SY-SUBRC    EQ 0    AND
           XVBUP-LFGSA CA 'AB'.
          CLEAR DA_SUM_KBMENG.
          REFRESH SAV_XVBEP.
          LOOP AT XVBEP FROM SAV_TABIX.
            IF XVBEP-VBELN NE XVBAP-VBELN OR
               XVBEP-POSNR NE XVBAP-POSNR.
              EXIT.
            ENDIF.
            MOVE XVBEP TO SAV_XVBEP. APPEND SAV_XVBEP.
          ENDLOOP.
          REFRESH SAV_XVBAP.
          MOVE XVBAP TO SAV_XVBAP.
          APPEND SAV_XVBAP.
          CALL FUNCTION 'RV_SCHEDULE_CHECK_DELIVERIES'
            EXPORTING
              FBELEG                  = XVBAK-VBELN
              FPOSNR                  = XVBAP-POSNR
              FVERRECHNUNG            = ' '
            TABLES
              FVBFA                   = XVBFA
              FVBUP                   = XVBUP
              FXVBEP                  = SAV_XVBEP
              FVBAP                   = SAV_XVBAP
            EXCEPTIONS
              FEHLER_BEI_LESEN_FVBUP  = 1
              FEHLER_BEI_LESEN_FXVBEP = 2.
          LOOP AT SAV_XVBEP.
            READ TABLE XVBEP WITH KEY MANDT = SY-MANDT
                                      VBELN = SAV_XVBEP-VBELN
                                      POSNR = SAV_XVBEP-POSNR
                                      ETENR = SAV_XVBEP-ETENR
                                                BINARY SEARCH.
            IF SY-SUBRC EQ 0.
              MOVE SAV_XVBEP TO XVBEP.
              MODIFY XVBEP INDEX SY-TABIX.
            ENDIF.
          ENDLOOP.
          LOOP AT XVBEP FROM SAV_TABIX.
            IF XVBEP-VBELN NE XVBAP-VBELN OR
               XVBEP-POSNR NE XVBAP-POSNR.
              EXIT.
            ENDIF.
            ADD XVBEP-BMENG TO DA_SUM_KBMENG.
            IF XVBEP-BMENG  IS INITIAL AND
               XVBEP-OLFMNG IS INITIAL AND
               XVBEP-VSMNG  IS INITIAL AND
               DA_SUM_KBMENG EQ XVBAP-KBMENG.
*             wenn nichts bestätigt ist, dann halt die Wunschliefermenge
*              XVBEP-OLFMNG = XVBEP-WMENG.
            ENDIF.
*            CHECK XVBEP-BMENG IS INITIAL OR
*                  NOT XVBEP-OLFMNG IS INITIAL.
              CLEAR VBKREDET.
              MOVE-CORRESPONDING XVBAK  TO VBKREDET.
              MOVE-CORRESPONDING XVBKD  TO VBKREDET.
              MOVE-CORRESPONDING XVBAP  TO VBKREDET.
              MOVE-CORRESPONDING XVBEP  TO VBKREDET.

            IF XVBEP-BMENG IS INITIAL AND
              XVBEP-OLFMNG IS INITIAL AND
              XVBEP-VSMNG  IS INITIAL AND
              DA_SUM_KBMENG EQ XVBAP-KBMENG.
              VBKREDET-OLFMNG = XVBEP-WMENG.
            ENDIF.

*           VBKREDET-KWKKC = VBKREDET-CMPRE * VBKREDET-OLFMNG.
            PERFORM CMPRE_CALCULATE(SAPLVKMP)
              USING    XVBAP-CMPRE
                       XVBAP-CMPRE_FLT
                       VBKREDET-OLFMNG
                       XVBEP-ABGES
              CHANGING VBKREDET-KWKKC
                       DA_DUMMY
                       VBKREDET-KWKKG.
            IF NOT VBKREDET-KWKKC IS INITIAL AND
               NOT XVBAK-CMWAE IS INITIAL.
              PERFORM STAT_CURR_CONVERT_EX(RMCS1000)
                USING    VBKREDET-KWKKC
                         XVBKD-PRSDT
                         XVBAP-ERDAT
                         XVBAK-WAERK
                         T001-WAERS
                         XVBAK-CMWAE
                         XVBKD-KURSK
                         XVBAP-CMKUA
                         XVBAK-KURST
                         'M'
                CHANGING VBKREDET-KWKKC.
            ENDIF.
            IF NOT VBKREDET-KWKKG IS INITIAL AND
               NOT XVBAK-CMWAE IS INITIAL.
              PERFORM STAT_CURR_CONVERT_EX(RMCS1000)
                USING    VBKREDET-KWKKG
                         XVBKD-PRSDT
                         XVBAP-ERDAT
                         XVBAK-WAERK
                         T001-WAERS
                         XVBAK-CMWAE
                         XVBKD-KURSK
                         XVBAP-CMKUA
                         XVBAK-KURST
                         'M'
                CHANGING VBKREDET-KWKKG.
            ENDIF.
            MOVE VBKREDET-KWKKC TO VBKREDET-KWKKB.
            MOVE VBKREDET-KWKKG TO VBKREDET-KWKKF.
            IF  NOT XVBUK-CMPSB IS INITIAL
                AND VBKREDET-MBDAT GT SAV_HORIZON.
              MOVE VBKREDET-KWKKB TO VBKREDET-KWKKD.
              MOVE VBKREDET-KWKKC TO VBKREDET-KWKKE.
              ADD VBKREDET-KWKKD TO CH_KWKKD.
              CLEAR: VBKREDET-KWKKB, VBKREDET-KWKKC.
            ENDIF.
            MOVE VBKREDET TO XVBKREDET.
            IF XVBEP-BMENG IS INITIAL AND
                XVBEP-OLFMNG IS INITIAL AND
                XVBEP-VSMNG  IS INITIAL AND
                DA_SUM_KBMENG EQ XVBAP-KBMENG.
              XVBKREDET-OLFMNG = XVBEP-OLFMNG.
            ENDIF.
            APPEND XVBKREDET.
          ENDLOOP.
        ELSE.
          CLEAR VBKREDET.
          CLEAR XVBAPF.
          READ TABLE XVBAPF WITH KEY VBELN = VBKRED-VBELN
                                     POSNR = XVBAP-POSNR  BINARY SEARCH.
          IF XVBAP-VRKME NE XVBAP-MEINS.
            PERFORM LAGERMENGE_BETRAG(SAPLMCS1) "hier Verkaufsmenge
              USING    XVBAP-MEINS
                       XVBAP-VRKME
                       XVBAP-UMVKN
                       XVBAP-UMVKZ
                       XVBAPF-ERLMENGE_F
              CHANGING XVBAPF-ERLMENGE_F.
            IF NOT XVBAPF-REMNG IS INITIAL.
              PERFORM LAGERMENGE_BETRAG(SAPLMCS1) "hier Verkaufsmenge
                USING    XVBAP-MEINS
                         XVBAP-VRKME
                         XVBAP-UMVKN
                         XVBAP-UMVKZ
                         XVBAPF-REMNG
                CHANGING XVBAPF-REMNG.
            ENDIF.
            IF NOT XVBAPF-WEMNG IS INITIAL.
              PERFORM LAGERMENGE_BETRAG(SAPLMCS1) "hier Verkaufsmenge
                USING    XVBAP-MEINS
                         XVBAP-VRKME
                         XVBAP-UMVKN
                         XVBAP-UMVKZ
                         XVBAPF-WEMNG
                CHANGING XVBAPF-WEMNG.
            ENDIF.
          ENDIF.
          OLFMNG_Q15 = VBKREDET-OLFMNG.
          PERFORM AUFTRAGSMENGE_ERMITTELN(SAPLMCS1)
            USING    XVBUP-FKSAA
                     XVBUP-FKSTA
                     XVBAP-FKREL
                     XVBAP-LSMENG
                     XVBAP-KWMENG
                     XVBAP-ZMENG
                     XVBAPF-REMNG
                     XVBAPF-WEMNG
            CHANGING OLFMNG_Q15.
          VBKREDET-OLFMNG = OLFMNG_Q15.
          IF NOT XVBAP-KZFME IS INITIAL.
*           Wirkstoff
            IF VBKREDET-OLFMNG GE XVBAPF-ERLMENGEFV.
              VBKREDET-OLFMNG = VBKREDET-OLFMNG - XVBAPF-ERLMENGEFV.
            ELSE.
              CLEAR VBKREDET-OLFMNG.
            ENDIF.
          ELSE.
*           unterstellt, daß Mengeneinheiten gleich
            IF VBKREDET-OLFMNG GE XVBAPF-ERLMENGE_F.
              VBKREDET-OLFMNG = VBKREDET-OLFMNG - XVBAPF-ERLMENGE_F.
            ELSE.
              CLEAR VBKREDET-OLFMNG.
            ENDIF.
          ENDIF.
          CHECK NOT VBKREDET-OLFMNG IS INITIAL.
          MOVE-CORRESPONDING XVBAK  TO VBKREDET.
          MOVE-CORRESPONDING XVBKD  TO VBKREDET.
          MOVE-CORRESPONDING XVBAP  TO VBKREDET.
          IF NOT XVBEP-MBDAT IS INITIAL.
            MOVE XVBEP-MBDAT          TO VBKREDET-MBDAT.
*           letzte bestätigte Einteilung bei Strecke
            IF NOT XVBEP-BANFN IS INITIAL AND
               NOT XVBEP-BNFPO IS INITIAL.
            DATA: SAV_BANFN LIKE VBEP-BANFN,
                  SAV_BNFPO LIKE VBEP-BNFPO.
            SAV_BANFN = XVBEP-BANFN.
            SAV_BNFPO = XVBEP-BNFPO.
              LOOP AT XVBEP FROM SAV_TABIX.
                IF XVBEP-BANFN NE SAV_BANFN OR
                   XVBEP-BNFPO NE SAV_BNFPO.
                  EXIT.
                ENDIF.
                IF XVBEP-BMENG GT 0.
                  VBKREDET-MBDAT = XVBEP-MBDAT.
                ENDIF.
              ENDLOOP.
            ENDIF.
          ELSE.
            MOVE XVBKD-FKDAT          TO VBKREDET-MBDAT.
          ENDIF.
*         VBKREDET-KWKKC = VBKREDET-CMPRE * VBKREDET-OLFMNG.
          PERFORM CMPRE_CALCULATE(SAPLVKMP)
            USING    XVBAP-CMPRE
                     XVBAP-CMPRE_FLT
                     VBKREDET-OLFMNG
                     XVBAP-ABGES
            CHANGING VBKREDET-KWKKC
                     DA_DUMMY
                     VBKREDET-KWKKG.
          IF NOT VBKREDET-KWKKC IS INITIAL AND
             NOT XVBAK-CMWAE IS INITIAL.
            PERFORM STAT_CURR_CONVERT_EX(RMCS1000)
              USING    VBKREDET-KWKKC
                       XVBKD-PRSDT
                       XVBAP-ERDAT
                       XVBAK-WAERK
                       T001-WAERS
                       XVBAK-CMWAE
                       XVBKD-KURSK
                       XVBAP-CMKUA
                       XVBAK-KURST
                       'M'
              CHANGING VBKREDET-KWKKC.
          ENDIF.
          IF NOT VBKREDET-KWKKG IS INITIAL AND
             NOT XVBAK-CMWAE IS INITIAL.
            PERFORM STAT_CURR_CONVERT_EX(RMCS1000)
              USING    VBKREDET-KWKKG
                       XVBKD-PRSDT
                       XVBAP-ERDAT
                       XVBAK-WAERK
                       T001-WAERS
                       XVBAK-CMWAE
                       XVBKD-KURSK
                       XVBAP-CMKUA
                       XVBAK-KURST
                       'M'
              CHANGING VBKREDET-KWKKG.
          ENDIF.
          MOVE VBKREDET-KWKKC TO VBKREDET-KWKKB.
          MOVE VBKREDET-KWKKG TO VBKREDET-KWKKF.
          MOVE VBKREDET TO XVBKREDET.
          APPEND XVBKREDET.
        ENDIF.
      ENDIF.
    ENDLOOP.
    MOVE CH_KWKKD TO CH_KWKKE.
  ELSE.
*   Lieferungen
    READ TABLE XLIKP WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN BINARY SEARCH.
    READ TABLE XVBUK WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN BINARY SEARCH.
    CHECK NOT XLIKP-VKORG IS INITIAL.
    PERFORM TVKO_READ(SAPLVKMP) USING    XLIKP-VKORG
                                CHANGING SAV_BUKRS.
    IF T001-BUKRS NE SAV_BUKRS.
      SELECT SINGLE * FROM T001
      WHERE BUKRS EQ SAV_BUKRS.
    ENDIF.
    READ TABLE LLIPS WITH KEY MANDT = SY-MANDT
                              VBELN = VBKRED-VBELN BINARY SEARCH.
    LOOP AT LLIPS FROM SY-TABIX.
      IF LLIPS-VBELN NE XLIKP-VBELN. EXIT. ENDIF.
      READ TABLE XVBUP WITH KEY MANDT = SY-MANDT
                                VBELN = VBKRED-VBELN
                                POSNR = LLIPS-POSNR  BINARY SEARCH.
      CLEAR LVBAP.
      READ TABLE LVBAP WITH KEY MANDT = SY-MANDT
                                VBELN = LLIPS-VGBEL
                                POSNR = LLIPS-VGPOS  BINARY SEARCH.
      MOVE LVBAP-CMPRE TO VBKREDET-CMPRE.
      CLEAR VBKREDET-OLFMNG.
      IF XVBUP-FKSTA CA 'AB'.
        MOVE LLIPS-LFIMG TO VBKREDET-OLFMNG.
      ENDIF.
      MOVE-CORRESPONDING XLIKP  TO VBKREDET.
      MOVE-CORRESPONDING LLIPS  TO VBKREDET.
      MOVE XVBKRED-CMNGV        TO VBKREDET-MBDAT.
*     MOVE XLIKP-WADAT_IST      TO VBKREDET-MBDAT.
*     IF VBKREDET-MBDAT IS INITIAL.
*       MOVE XLIKP-WADAT          TO VBKREDET-MBDAT.
*     ENDIF.
*     VBKREDET-KWKKC = LVBAP-CMPRE * VBKREDET-OLFMNG.
      PERFORM CMPRE_CALCULATE(SAPLVKMP)
        USING    LVBAP-CMPRE
                 LVBAP-CMPRE_FLT
                 VBKREDET-OLFMNG
                 LLIPS-ABGES
        CHANGING VBKREDET-KWKKC
                 DA_DUMMY
                 VBKREDET-KWKKG.
      IF NOT VBKREDET-KWKKC IS INITIAL AND
         NOT XVBKRED-CMWAE  IS INITIAL.
        CLEAR:     XVBKD-KURSK.
        PERFORM STAT_CURR_CONVERT_EX(RMCS1000)
          USING    VBKREDET-KWKKC
                   XLIKP-ERDAT
                   LVBAP-ERDAT
                   LVBAP-WAERK
                   T001-WAERS
                   XVBKRED-CMWAE
                   XVBKD-KURSK
                   LVBAP-CMKUA
                   'M'
                   'M'
          CHANGING VBKREDET-KWKKC.
      ENDIF.
      IF NOT VBKREDET-KWKKG IS INITIAL AND
         NOT XVBKRED-CMWAE  IS INITIAL.
        CLEAR:     XVBKD-KURSK.
        PERFORM STAT_CURR_CONVERT_EX(RMCS1000)
          USING    VBKREDET-KWKKG
                   XLIKP-ERDAT
                   LVBAP-ERDAT
                   LVBAP-WAERK
                   T001-WAERS
                   XVBKRED-CMWAE
                   XVBKD-KURSK
                   LVBAP-CMKUA
                   'M'
                   'M'
          CHANGING VBKREDET-KWKKG.
      ENDIF.
      MOVE VBKREDET-KWKKC TO VBKREDET-KWKKB.
      MOVE VBKREDET-KWKKG TO VBKREDET-KWKKF.
      MOVE VBKREDET TO XVBKREDET.
      APPEND XVBKREDET.
    ENDLOOP.
  ENDIF.
ENDFORM.                    "VBKREDET_FUELLEN

*---------------------------------------------------------------------*
*       FORM VBUK_LESEN                                               *
*---------------------------------------------------------------------*
*       Belegkopf wird gelesen und in die interne Arbeitstabelle      *
*       abgelegt                                                      *
*---------------------------------------------------------------------*
FORM VBUK_LESEN.
  DATA: TABLE_SIZE LIKE SY-TFILL.

  CLEAR RC.
  REFRESH XVBELN.
  REFRESH YVBELN.

* Ermitteln Belege über angegebenen Matchcode
  IF NOT ( ORDER IS INITIAL ).
    IF FLG_TABELLE EQ CON_MACO.
      PERFORM MATCHCODE_LESEN USING 'VMVA' 'H'.
    ENDIF.
    IF RC = 0.
* Belegkoepfe werden im 100-Block gelesen.
      DO.
        PERFORM YVBELN_FUELLEN.

        SELECT * FROM VBUK APPENDING TABLE XVBUK WHERE VBELN IN YVBELN
                                                 AND   GBSTK IN GBSTK
                                                 AND   CMGST IN CMGST
                                             AND VBOBJ = VERKAUFSBELEG
        ORDER BY PRIMARY KEY.
* Sind keine Belege mehr vorggeben, wird die Selektionsschleife
* verlassen.
        DESCRIBE TABLE XVBELN LINES SY-TFILL.
        IF SY-TFILL = 0.
          EXIT.
        ENDIF.
      ENDDO.
    ENDIF.
  ENDIF.

* Lieferungen
  IF NOT ( DELIV IS INITIAL ).
    REFRESH XVBELN.
    REFRESH YVBELN.
    IF FLG_TABELLE EQ CON_MACO.
      PERFORM MATCHCODE_LESEN USING 'VMVL' 'D'.
    ENDIF.
    IF RC = 0.
* Belegkoepfe werden im 100-Block gelesen.
      DO.
        PERFORM YVBELN_FUELLEN.
        SELECT * FROM VBUK APPENDING TABLE XVBUK WHERE VBELN IN YVBELN
                                                 AND   GBSTK IN GBSTK
                                                 AND   CMGST IN CMGST
                                                 AND   VBOBJ = LIEFERUNG
        ORDER BY PRIMARY KEY.
* Sind keine Belege mehr vorggeben, wird die Selektionsschleife
* verlassen.
        DESCRIBE TABLE XVBELN LINES SY-TFILL.
        IF SY-TFILL = 0.
          EXIT.
        ENDIF.
      ENDDO.
    ENDIF.
  ENDIF.
  SORT XVBUK BY MANDT VBELN.
ENDFORM.                    "VBUK_LESEN

*---------------------------------------------------------------------*
*       FORM YVBELN_FUELLEN                                           *
*---------------------------------------------------------------------*
*       Fuellen Selektionstabelle Beleg im 100-Block                  *
*---------------------------------------------------------------------*
FORM YVBELN_FUELLEN.
  REFRESH YVBELN.
  DESCRIBE TABLE XVBELN LINES SY-TFILL.
  IF SY-TFILL = 0.
    DESCRIBE TABLE VBELN LINES SY-TFILL.
    IF SY-TFILL > 0.
      XVBELN[] = VBELN[].
    ENDIF.
  ENDIF.

  IF SY-TFILL > 100.
    TABLE_SIZE = 100.
  ELSE.
    TABLE_SIZE = SY-TFILL.
  ENDIF.


* Füllen Selektionstabelle für die Belege
  DO TABLE_SIZE TIMES.
    READ TABLE XVBELN INDEX 1.
    YVBELN = XVBELN.
    APPEND YVBELN.
    DELETE XVBELN INDEX 1.
  ENDDO.
ENDFORM.                    "YVBELN_FUELLEN

