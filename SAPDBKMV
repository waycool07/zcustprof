*       FORM CREDIT_EXPOSURE                                          *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
FORM CREDIT_EXPOSURE.
* FSCM: SAP Credit Management
    STATICS: sv_cm_checked,
             sv_cm_message,
             sv_ukm_active,
             sv_ukm_erp2005.

    IF sv_cm_checked IS INITIAL.
      CALL FUNCTION 'UKM_IS_ACTIVE'
        IMPORTING
          e_active  = sv_ukm_active
          e_erp2005 = sv_ukm_erp2005.
      sv_cm_checked = 'X'.
    ENDIF.
IF sv_ukm_erp2005 IS INITIAL.
 ON CHANGE OF XVBKRED-KNKLI
  OR           XVBKRED-KKBER.
    LOOP AT XKNKK WHERE KNKLI = XVBKRED-KNKLI
                  AND   KKBER = XVBKRED-KKBER.
      EXIT.
    ENDLOOP.
    IF SY-SUBRC = 0.
      MOVE-CORRESPONDING XKNKK TO XVBKRED.
    ELSE.
      CALL FUNCTION 'CREDIT_EXPOSURE'
        EXPORTING
          KKBER         = XVBKRED-KKBER
          KUNNR         = XVBKRED-KNKLI
        IMPORTING
          PERCENTAGE    = XVBKRED-KLPRZ
          OPEN_DELIVERY = XVBKRED-OLIKW
          OPEN_INVOICE  = XVBKRED-OFAKW
          OPEN_ORDER    = XVBKRED-OEIKW
          E_KNKK        = KNKK.
      IF KNKK IS INITIAL.
        PERFORM CREDIT_NEW_CUSTOMER_DATA(SAPLVKMP)          "K11K100948
          USING    XVBKRED-KKBER XVBKRED-KNKLI              "K11K100948
          CHANGING KNKK.                                    "K11K100948
      ENDIF.                                                "K11K100948
      MOVE-CORRESPONDING KNKK TO XVBKRED.
      MOVE-CORRESPONDING XVBKRED TO XKNKK.
      APPEND XKNKK.
    ENDIF.
  ELSE.
    MOVE-CORRESPONDING XKNKK TO XVBKRED.
  ENDON.
 ENDIF.
ENDFORM.                    "CREDIT_EXPOSURE

*---------------------------------------------------------------------*
*       FORM ZAHLUNGSBEDINGUNGEN_ERMITTELN                            *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
*  -->  BELEG                                                         *
*  -->  VALUE                                                         *
*  -->  (POSITION)                                                    *
*  -->  ZBED                                                          *
*---------------------------------------------------------------------*
FORM ZAHLUNGSBEDINGUNGEN_ERMITTELN USING BELEG
                                   VALUE(POSITION)
                                   ZBED.
  IF POSITION IS INITIAL.
    POSITION     = '000000'.
  ENDIF.
  POSITIONS_KEY-MANDT = SY-MANDT.
  POSITIONS_KEY-VBELN = BELEG.
  POSITIONS_KEY-POSNR = POSITION.
  READ TABLE XVBKD WITH KEY POSITIONS_KEY BINARY SEARCH.
  IF SY-SUBRC NE 0.
    SELECT * FROM VBKD APPENDING TABLE XVBKD
                       WHERE VBELN = BELEG
                       AND   POSNR = POSITION.
    SORT XVBKD.
    READ TABLE XVBKD WITH KEY POSITIONS_KEY BINARY SEARCH.
  ENDIF.
  ZBED         = XVBKD-ZTERM.
ENDFORM.                    "ZAHLUNGSBEDINGUNGEN_ERMITTELN
