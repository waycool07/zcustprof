FORM PUT_VBKRED.
  PERFORM VBAK_ODER_VBUK CHANGING FLG_TABELLE.
  IF FLG_TABELLE EQ CON_VBUK OR
     FLG_TABELLE EQ CON_MACO.
    PERFORM VBUK_LESEN.
    PERFORM VBAK_LESEN.
    PERFORM FPLA_LESEN.
    PERFORM VBAP_LESEN.
    PERFORM LIKP_LESEN.
  ELSE.
    PERFORM VBAK_LESEN_VOR_VBUK.
    PERFORM FPLA_LESEN.
    PERFORM LIKP_LESEN_VOR_VBUK.
    PERFORM VBUK_LESEN_NACH_VBAK.
    PERFORM VBAP_LESEN.
  ENDIF.
  PERFORM VBPA_LESEN.
  PERFORM VBKRED_FUELLEN.
* CALL FUNCTION 'SD_VBKRED_POSITIONS_FILL'
*      TABLES
*           YVBAP = XVBAP
*           YVBEP = YVBEP
*           YVBUK = XVBUK
*           YVBAK = XVBAK.
* IF NOT ( POSI IS INITIAL ).
*   CALL FUNCTION 'SD_VBKRED_POSITIONS'
*        TABLES
*             XVBKRED = XVBKRED.
* ENDIF.
  CLEAR T691F.
  LOOP AT XVBKRED.
    VBKRED = XVBKRED.
    PERFORM VBKREDET_FUELLEN CHANGING VBKRED-KWKKD          "P30K028860
                                      VBKRED-KWKKE.         "P30K028860
    PUT VBKRED.
  ENDLOOP.
