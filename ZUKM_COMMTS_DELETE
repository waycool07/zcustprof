      g_formname_pf_status    TYPE slis_formname VALUE
      'ALV_PF_STATUS_SET',
      g_formname_pf_statusa   TYPE slis_formname VALUE
      'ALV_PF_STATUS_SETA'.
DATA: g_repid LIKE sy-repid.
DATA: gt_list_top_of_page TYPE slis_t_listheader.
DATA: gt_list_top_of_pagea TYPE slis_t_listheader.
DATA: gt_list_end_of_list TYPE slis_t_listheader.
DATA:
            g_save(1) TYPE c,
            g_exit(1) TYPE c.
DATA:       gx_variant LIKE disvariant,
            g_variant LIKE disvariant.
**
DATA: sel_segment TYPE  ukm_t_credit_sgmnt_ranges.


SELECT-OPTIONS: s_partnr FOR ukmbp_cms_sgm-partner,
                s_segmt FOR ukmbp_cms_sgm-credit_sgmnt,
                s_comtyp FOR ukm_totals-comm_typ, "nicht ter
                s_curr  FOR ukm_totals-currency NO-DISPLAY.
PARAMETER:      p_date LIKE ukm_parameter-eff_date.

PARAMETERS:     x_err  AS CHECKBOX, "nur mit item_error = 'X'
                x_pend AS CHECKBOX. "nur mit Pending messages.
PARAMETERS:     p_vari LIKE disvariant-variant.
PARAMETERS:     x_bupr LIKE ukm_parameter-xbupr DEFAULT 'X'.

SELECTION-SCREEN BEGIN OF BLOCK 01 WITH FRAME TITLE text-200.
PARAMETERS:     del_tot  LIKE ukm_comm_dynpro_fields-del_totals.
PARAMETERS:     del_item LIKE ukm_comm_dynpro_fields-del_item.

PARAMETERS:     rebuild LIKE ukm_parameter-xrebuild.
SELECTION-SCREEN END OF BLOCK 01.
PARAMETER: p_show(1) DEFAULT ' ' NO-DISPLAY .
* if called by transaction UKM_BP
PARAMETERS:     x_single(1) NO-DISPLAY.

SELECTION-SCREEN BEGIN OF SCREEN 0900 TITLE text-100 AS WINDOW.

PARAMETERS:     ps_date LIKE ukm_parameter-eff_date.

SELECTION-SCREEN END OF SCREEN 0900.


INITIALIZATION.
  g_repid = sy-repid.
* Schalter Varianten benutzerspezifisch/allgemein speicherbar szen
* Set Options: save variants userspecific or general
  g_save = 'A'.
  CLEAR g_variant.
  g_variant-report = g_repid.
  g_variant-handle = '0001'.
* Get default variant
  gx_variant = g_variant.
  CALL FUNCTION 'REUSE_ALV_VARIANT_DEFAULT_GET'
    EXPORTING
      i_save     = g_save
    CHANGING
      cs_variant = gx_variant
    EXCEPTIONS
      not_found  = 2.
  IF sy-subrc = 0.
    p_vari = gx_variant-variant.
  ENDIF.
************
  PERFORM set_get_params USING 'GET'.


AT SELECTION-SCREEN.
  DATA:
    l_activity(2) TYPE n.

  IF NOT rebuild  IS INITIAL OR
     NOT del_item IS INITIAL OR
     NOT del_tot  IS INITIAL.
    l_activity = '02'.
  ELSE.
    l_activity = '03'.
  ENDIF.

  SELECT credit_sgmnt FROM ukmcred_sgm0c INTO ukmbp_cms_sgm-credit_sgmnt
      WHERE credit_sgmnt IN s_segmt.
    AUTHORITY-CHECK OBJECT 'F_UKM_SGMT'
         ID 'ACTVT' FIELD l_activity
         ID 'UKM_SGMNT' FIELD ukmbp_cms_sgm-credit_sgmnt.
    IF sy-subrc <> 0.
      MESSAGE e002(ukm_bp) WITH ukmbp_cms_sgm-credit_sgmnt.
    ENDIF.
  ENDSELECT.




* Process on value request
AT SELECTION-SCREEN ON VALUE-REQUEST FOR p_vari.
  PERFORM alv_f4_for_variant.


START-OF-SELECTION.
*
*-------------set params
  PERFORM set_get_params USING 'SET'.

DATA: i_sel TYPE STANDARD TABLE OF rsparams WITH HEADER LINE.
  IMPORT i_sel FROM MEMORY ID 'ZCREX'.
  IF i_sel[] IS NOT INITIAL.
    LOOP AT i_sel .
      CASE  i_sel-selname.
        WHEN 'S_PARTNR'.
          CHECK i_sel-low IS NOT INITIAL.
          s_partnr-sign = 'I'.
          s_partnr-option = 'EQ'.
          s_partnr-low = i_sel-low.
          APPEND s_partnr.
         WHEN 'P_SHOW'.
          CHECK i_sel-low IS NOT INITIAL.
          p_show = i_sel-low.
        endcase.
      ENDLOOP.
   endif.
*
  IF NOT ps_date IS INITIAL.
    p_date = ps_date.
  ENDIF.
  g_variant-variant = p_vari.

  PERFORM alv_e01_fieldcat_init  USING gt_fieldcat[].
  PERFORM alv_e03_eventtab_build USING gt_events[].
  PERFORM alv_e04_comment_build  USING gt_list_top_of_page[].
  PERFORM alv_e08_comment_build  USING gt_list_end_of_list[].
  PERFORM alv_e06_t_sort_build   USING gt_sort[].
  PERFORM alv_e07_sp_group_build USING gt_sp_group[].
*
* Hauptkreditsegment
  PERFORM set_main_segment.
  PERFORM alv_set_fieldcat.

  IF x_bupr <> space.
    x_inferior = space.
  ELSE.
    x_inferior = 'X'.
  ENDIF.
*
* setup main segment result
  IF g_main_segment IN s_segmt.
    CALL FUNCTION 'UKM_COMMTS_SET_SEGMENT_SELOPT'
      IMPORTING
        et_range = sel_segment.
    IF x_pend IS INITIAL AND x_err IS INITIAL.
      SELECT DISTINCT *
             FROM ukm_totals
             INTO CORRESPONDING FIELDS OF TABLE gt_acc
             WHERE partner IN s_partnr
             AND ( credit_sgmnt IN sel_segment
             OR  credit_sgmnt = g_main_segment ).
* Hauptsegment einsetzen
      LOOP AT gt_acc INTO gs_acc.
        gs_acc-credit_sgmnt = g_main_segment.
        MODIFY gt_acc FROM gs_acc TRANSPORTING credit_sgmnt.
      ENDLOOP.
    ENDIF.
  ENDIF.

* do varios selections
  IF x_pend IS INITIAL.
    REFRESH r_error. CLEAR r_error.
    IF NOT x_err IS INITIAL.
      CLEAR r_error.
      r_error-low = 'X'.
      r_error-sign = 'I'.
      r_error-option = 'EQ'.
      APPEND r_error.
    ENDIF.
* select by ukm_totals
    IF NOT s_curr[] IS INITIAL OR
     NOT s_comtyp[] IS INITIAL.
      SELECT DISTINCT * FROM ukm_totals
              APPENDING CORRESPONDING FIELDS OF TABLE gt_acc
              WHERE partner IN s_partnr
               AND credit_sgmnt IN s_segmt
               AND currency IN s_curr
               AND comm_typ IN s_comtyp.
    ENDIF.
*  use the credit accounts
    SELECT * FROM ukmbp_cms_sgm
                  APPENDING CORRESPONDING FIELDS OF TABLE gt_acc
                  WHERE partner IN s_partnr
                  AND credit_sgmnt IN s_segmt
                  AND item_error IN r_error.


  ELSE.
*  nur welche mit pending messages
    SELECT DISTINCT * FROM ukm_pm_balance
                 APPENDING CORRESPONDING FIELDS OF TABLE gt_acc
                 WHERE partner IN s_partnr
                 AND credit_sgmnt IN s_segmt
                 AND currency IN s_curr
                 AND comm_typ IN s_comtyp.
    .

  ENDIF.

  SORT gt_acc.
  IF NOT x_single IS INITIAL.
    LOOP AT s_partnr.
      gs_acc-partner = s_partnr-low.
    ENDLOOP.
    LOOP AT s_segmt.
      gs_acc-credit_sgmnt = s_segmt-low.
    ENDLOOP.
    APPEND gs_acc TO gt_acc.
    SORT gt_acc.
  ENDIF.
  DELETE ADJACENT DUPLICATES FROM gt_acc.
* duplicates removed
  IF NOT rebuild IS INITIAL OR NOT del_item IS INITIAL.
    SELECT DISTINCT *
         FROM ukm_item
         APPENDING CORRESPONDING FIELDS OF TABLE gt_acc
         WHERE partner IN s_partnr
         AND comm_typ   IN s_comtyp
         AND currency   IN s_curr
         AND credit_sgmnt IN s_segmt.
    SORT gt_acc.
    DELETE ADJACENT DUPLICATES FROM gt_acc.

  ENDIF.
* partner beziehungen auswerten
END-OF-SELECTION.

  LOOP AT gt_acc INTO gs_acc.
    COLLECT gs_acc-partner INTO gt_partner.
    COLLECT gs_acc-credit_sgmnt INTO gt_segment.
  ENDLOOP.
*
  IF NOT del_tot IS INITIAL OR NOT rebuild IS INITIAL.
    gs_enq-partner_high = gs_acc-partner.
    READ TABLE gt_acc INDEX 1 INTO gs_acc.
    gs_enq-partner_low = gs_acc-partner.
    CALL FUNCTION 'UKM_ENQUEUE_SET'
      EXPORTING
        i_partner_low  = gs_enq-partner_low
        i_partner_high = gs_enq-partner_high
      EXCEPTIONS
        foreign_lock   = 1
        OTHERS         = 4.
    CASE sy-subrc.
      WHEN 1.
        MESSAGE e001 WITH sy-msgv1 sy-msgv2.
      WHEN 4.
        MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
            WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
    ENDCASE.

  ENDIF.
* differenzierung nach Obligotyp beim Loeschen
  IF NOT s_comtyp[] IS INITIAL.
    SELECT * FROM ukmcomm_types INTO CORRESPONDING FIELDS OF
             TABLE gt_comm_typ
             WHERE comm_typ IN s_comtyp.
  ENDIF.

  DATA:
    lt_partner_package TYPE TABLE OF bu_partner,
    l_total_size TYPE sy-tabix,
    l_start      TYPE sy-tabix,
    l_end        TYPE sy-tabix.

  DESCRIBE TABLE gt_partner LINES l_total_size.

  l_start = 1.
  l_end   = 0.

  WHILE l_end < l_total_size.
    ADD 1000 TO l_end.

    IF l_total_size < l_end.
      l_end = l_total_size.
    ENDIF.

    REFRESH lt_partner_package.
    APPEND LINES OF gt_partner FROM l_start TO l_end
           TO lt_partner_package.

    CALL FUNCTION 'UKM_COMMTS_BUPR_PREREAD'
      TABLES
        t_partner  = lt_partner_package
        t_segments = gt_segment.

    ADD 1000 TO l_start.
  ENDWHILE.


  IF rebuild IS INITIAL.
    CALL FUNCTION 'UKM_COMMTS_PREREAD'
      TABLES
        t_partner  = gt_partner
        t_segments = gt_segment.
  ENDIF.

  CALL FUNCTION 'UKM_COMMTS_BUFFER_REFRESH'
    EXPORTING
      new_buffer = 'X'
      old_buffer = 'X'.

  IF NOT del_tot IS INITIAL OR NOT rebuild IS INITIAL.
    CALL FUNCTION 'UKM_COMMTS_PREREAD'
      EXPORTING
        i_free_table = 'X'.
  ENDIF.

  LOOP AT gt_acc INTO gs_acc.
*   delete totals
    IF NOT del_tot IS INITIAL OR NOT rebuild IS INITIAL.
      CALL FUNCTION 'UKM_COMMTS_DELETE'
        EXPORTING
          i_partner   = gs_acc-partner
          i_segment   = gs_acc-credit_sgmnt
        TABLES
          it_comm_typ = gt_comm_typ.
      COMMIT WORK AND WAIT.
    ENDIF.
*   items löschen
    IF NOT del_item IS INITIAL.
      CALL FUNCTION 'UKM_ITEMS_DELETE'
        EXPORTING
          i_partner   = gs_acc-partner
          i_segment   = gs_acc-credit_sgmnt
        TABLES
          it_comm_typ = gt_comm_typ.
      COMMIT WORK AND WAIT.
    ENDIF.
*  Neue totals aufbauen
    IF NOT rebuild IS INITIAL.
      IF del_item IS INITIAL.

        CALL FUNCTION 'UKM_ITEMS_READ'
          EXPORTING
            i_partner         = gs_acc-partner
            i_segment         = gs_acc-credit_sgmnt
            i_inferior        = ' '
*             I_DATE            =
*             I_IGUID           =
*             I_FROM_DATE       =
          TABLES
            et_ukm_item       = gt_item.
      ELSE.
        REFRESH gt_item.
      ENDIF.
*    erst mal totals und items aktualisieren
*     COMMIT WORK.
      CALL FUNCTION 'UKM_COMMITMENTS_CALCULATE'
       EXPORTING
         i_rebuild              = 'X'
         i_update               = 'X'
*        I_EFF_DATE             =
        TABLES
          t_ukm_item             = gt_item
             EXCEPTIONS
        OTHERS = 0.

    ENDIF.
  ENDLOOP.
*  aus buffer in DB
  IF NOT rebuild IS INITIAL.
    CALL FUNCTION 'UKM_COMMITMENTS_UPD_GET_TABLES'
      TABLES
        et_item_new       = lt_item
        et_totals_new     = lt_totals
        et_totals_new_abs = lt_totals_abs
        et_pm_balance_new = lt_pm_balance.

*   change only those in gt_comm_typ.
    if gt_comm_typ[] is not initial.
      delete lt_totals where comm_typ not in s_comtyp.
      delete lt_totals_abs where comm_typ not in s_comtyp.
    endif.

    CALL FUNCTION 'UKM_COMMITMENTS_UPDATE'
      TABLES
        it_item_new       = lt_item
        it_totals_new     = lt_totals
        it_totals_new_abs = lt_totals_abs
        it_pm_balance_new = lt_pm_balance.

  ENDIF.

  IF NOT del_tot IS INITIAL OR NOT rebuild IS INITIAL.
    CALL FUNCTION 'UKM_ENQUEUE_SET'
      EXPORTING
        i_partner_low  = gs_enq-partner_low
        i_partner_high = gs_enq-partner_high
        i_dequeue      = 'X'.
  ENDIF.

  IF NOT del_tot IS INITIAL OR NOT rebuild IS INITIAL
   OR NOT del_item IS INITIAL.
    COMMIT WORK.
    CALL FUNCTION 'UKM_COMMTS_BUFFER_REFRESH'
      EXPORTING
        new_buffer = 'X'
        old_buffer = 'X'.
  ENDIF.
*-display

  LOOP AT gt_acc INTO gs_acc.
* obligo des aktuellen partners
    REFRESH: gt_totals, lt_display, gt_totals_source.
*  Neue totals aufbauen
    IF x_bupr <> space.
      x_inferior = ' '.
    ELSE.
      x_inferior = 'X'.
    ENDIF.
*   with/without dependent accts
    IF x_bupr <> space.
      CALL FUNCTION 'UKM_COMMTS_READ'
        EXPORTING
          i_partner            = gs_acc-partner
          i_segment            = gs_acc-credit_sgmnt
          i_date               = p_date
          i_inferior           = 'X'
        TABLES
          et_ukm_totals_source = gt_totals_source.
    ELSE.
      CALL FUNCTION 'UKM_COMMTS_READ'
        EXPORTING
          i_partner            = gs_acc-partner
          i_segment            = gs_acc-credit_sgmnt
          i_date               = p_date
          i_inferior           = ' ' "?'X' "x_inferior
        TABLES
          et_ukm_totals_source = gt_totals_source. "wg meldesegmetn
*<         et_ukm_totals = gt_totals.
*<     gt_totals_source[] = gt_totals[].

    ENDIF.
*   apply further selections.
    LOOP AT gt_totals_source INTO gs_totals_source.
      IF NOT gs_totals_source-currency IN s_curr
         OR NOT gs_totals_source-comm_typ IN s_comtyp.
        DELETE gt_totals_source.
      ENDIF.
    ENDLOOP.

*   umrubeln
    CALL FUNCTION 'UKM_COMMTS_TOTALS_CALCULATE'
      TABLES
        it_totals_source  = gt_totals_source
        et_totals_display = lt_display
      EXCEPTIONS
        OTHERS            = 0.
    LOOP AT lt_display INTO ls_display.
      MOVE-CORRESPONDING ls_display TO ls_totalsdisplay.
*     get business partner data
      AT NEW partner.
*        CALL FUNCTION 'BUP_BUT000_SELECT_SINGLE'
*          EXPORTING
*            i_partner = ls_display-partner
*          IMPORTING
*            e_but000  = l_but000
*          EXCEPTIONS
*            not_found = 1.
*        IF sy-subrc = 0.
*          CONCATENATE l_but000-name_last
*                      l_but000-name_org1
*                      l_but000-name_grp1
*                      INTO lname.
*       condense lname.
        CALL FUNCTION 'UKM_GET_DESCRIPTION_FOR_GPART'
          EXPORTING
            i_partner          = ls_display-partner
          IMPORTING
            e_description_name = lname.
        IF NOT lname IS INITIAL.
          ls_totalsdisplay-name_last = lname.
        ELSE.
          ls_totalsdisplay-name_last = text-014.

        ENDIF.

      ENDAT.
*     get credit segment desciption.
      AT NEW credit_sgmnt.
        SELECT SINGLE credit_sgmnt_txt FROM ukmcred_sgm0t INTO
                           ls_totalsdisplay-credit_sgmnt_txt
        WHERE credit_sgmnt = ls_display-credit_sgmnt
          AND   langu        = sy-langu.
        IF sy-subrc <> 0.
          ls_totalsdisplay-credit_sgmnt_txt = text-042.
        ENDIF.
      ENDAT.

      APPEND ls_totalsdisplay TO gt_totalsdisplay.

    ENDLOOP.

  ENDLOOP.

data gt_totalsdisplay1 like table of ls_totalsdisplay.
  gt_totalsdisplay1[] = gt_totalsdisplay[].
  EXPORT gt_totalsdisplay1 TO MEMORY ID 'ZFCREX'.
*
* display
  gs_layout-f2code = '&ETA'.
  gs_layout-f2code = 'ITEM_PICK'. "springe in item liste.

  gs_layout-get_selinfos ='X'.

if p_show is NOT INITIAL.
  CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'
       EXPORTING
            i_callback_program      = g_repid
            i_callback_user_command  = g_formname_user_command
            i_callback_pf_status_set = g_formname_pf_status
*            i_callback_html_top_of_page = 'HTML_TOP_OF_PAGE'
*            i_callback_html_end_of_list = 'HTML_END_OF_LIST'
            i_callback_top_of_page = 'ALV_TOP_OF_PAGE'
*              I_GRID_SETTINGS        = GS_GRID_SETTINGS
*            i_structure_name        = 'UKM_S_TOTALS_DISPLAY'
            is_layout               = gs_layout
            it_fieldcat             = gt_fieldcat[]
*           IT_EXCLUDING            =
            it_special_groups       = gt_sp_group[]
            it_sort                 = gt_sort[]
*           IT_FILTER               =
*           IS_SEL_HIDE             =
*           i_default               = g_default
            i_save                  = g_save
            is_variant              = g_variant
            it_events               = gt_events[]
*           IT_EVENT_EXIT           =
            is_print                = gs_print
*           I_SCREEN_START_COLUMN   = 0
*           I_SCREEN_START_LINE     = 0
*           I_SCREEN_END_COLUMN     = 0
*           I_SCREEN_END_LINE       = 0
*      IMPORTING
*           E_EXIT_CAUSED_BY_CALLER =
       TABLES
            t_outtab                = gt_totalsdisplay.
endif.
*---------------------------------------------------------------------
FORM set_get_params USING imode.
  CASE imode.
    WHEN 'GET'.
      GET PARAMETER ID 'BPA' FIELD s_partnr-low.
      IF sy-subrc = 0 AND NOT s_partnr-low IS INITIAL.
        s_partnr-sign = 'I'.
        s_partnr-option = 'EQ'.
        APPEND s_partnr.
      ENDIF.
      GET PARAMETER ID 'UKM_SEGMENT' FIELD s_segmt-low.
      IF sy-subrc = 0 AND NOT s_segmt-low IS INITIAL.
        s_segmt-sign = 'I'.
        s_segmt-option = 'EQ'.
        APPEND s_segmt.
      ENDIF.

    WHEN 'SET'.
      READ TABLE s_partnr INDEX 1.
      IF sy-subrc = 0 AND s_partnr-sign = 'I' AND s_partnr-option = 'EQ'
          AND NOT s_partnr-low IS INITIAL.
        SET PARAMETER ID 'BPA' FIELD s_partnr-low.
      ENDIF.
      READ TABLE s_segmt INDEX 1.
      IF sy-subrc = 0 AND s_segmt-sign = 'I' AND s_segmt-option = 'EQ'
          AND NOT s_segmt-low IS INITIAL.
        SET PARAMETER ID 'UKM_SEGMENT' FIELD s_segmt-low.
      ENDIF.

  ENDCASE.
ENDFORM.                    "set_get_params


*&--------------------------------------------------------------------*
*&      Form  alv_f4_for_variant
*&--------------------------------------------------------------------*
*       text
*---------------------------------------------------------------------*
FORM alv_f4_for_variant.
*
  CALL FUNCTION 'REUSE_ALV_VARIANT_F4'
       EXPORTING
            is_variant          = g_variant
            i_save              = g_save
            i_display_via_grid  = 'X'
*           it_default_fieldcat =
       IMPORTING
            e_exit              = g_exit
            es_variant          = gx_variant
       EXCEPTIONS
            not_found = 2.
  IF sy-subrc = 2.
    MESSAGE ID sy-msgid TYPE 'S'      NUMBER sy-msgno
            WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
  ELSE.
    IF g_exit = space.
      p_vari = gx_variant-variant.
    ENDIF.
  ENDIF.
ENDFORM.                    "ALV_F4_FOR_VARIANT
