*---------------------------------------------------------------------*
*      -->I_UCOMM    text
*      -->I_SELFIELD text
*---------------------------------------------------------------------*
FORM user_command_item USING
                        i_selfield TYPE slis_selfield.      "#EC CALLED

  RANGES: lr_partnr FOR ls_totalsdisplay-partner.

  lr_partnr[] = s_partnr[].

*determine the current line
  READ TABLE gt_totalsdisplay INTO ls_totalsdisplay
             INDEX   i_selfield-tabindex.
  IF sy-subrc <> 0.
    IF i_selfield-tabindex = 0 AND
    i_selfield-sumindex <> 0.
      IF i_selfield-sel_tab_field CS 'PARTNER'.
        REFRESH lr_partnr.
        lr_partnr-low = i_selfield-value.
        lr_partnr-sign = 'I'.
        lr_partnr-option = 'EQ'.
        APPEND lr_partnr.
      ELSE.
        MESSAGE e039(0k).
      ENDIF.
    ENDIF.
  ELSE.
    REFRESH lr_partnr.
    lr_partnr-low = ls_totalsdisplay-partner.
    lr_partnr-sign = 'I'.
    lr_partnr-option = 'EQ'.
    APPEND lr_partnr.
  ENDIF.


  SUBMIT ukm_item_display
         WITH s_partnr IN lr_partnr
         WITH s_segmt  IN s_segmt
         WITH s_comtyp IN s_comtyp
         WITH s_curr   IN s_curr
         WITH p_date   = p_date
         AND RETURN.

ENDFORM.                    "user_command_item

