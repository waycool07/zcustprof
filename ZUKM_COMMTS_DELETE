DATA: gt_acc TYPE TABLE OF ukm_s_account.
DATA: gs_acc LIKE LINE OF gt_acc.

DATA: gt_partner TYPE TABLE OF bu_partner,
      gt_segment TYPE TABLE OF ukm_credit_sgmnt.

