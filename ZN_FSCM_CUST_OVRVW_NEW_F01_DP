*&---------------------------------------------------------------------*
*&      Form  sub_get_bsid
*&---------------------------------------------------------------------*
* Subroutine to retrieve data for Aging summary from Accounting:       *
* Secondary Index for Customers (BSID) table                           *
*----------------------------------------------------------------------*
FORM sub_get_bsid.

  DATA: l_duedt TYPE bldat.

  IF NOT g_rpartner[] IS INITIAL.
    SELECT bukrs    "Company Code
           kunnr    "Customer Number 1
           bldat    "Document Date in Document
           shkzg    "Debit/Credit Indicator
           dmbtr    "Amount in Local Currency
           zfbdt    "Baseline Date for Due Date Calculation
           zbd1t    "Cash discount days 1
           zbd2t    "Cash discount days 2
           zbd3t    "Net Payment Terms Period
           rebzg    "Number of the Invoice the Transaction Belongs to
    INTO TABLE gt_bsid
    FROM bsid   "Accounting: Secondary Index for Customers
    WHERE bukrs = p_bukrs
    AND   kunnr IN g_rpartner.
*    CHECK sy-subrc = 0.    "GS002-
    IF sy-subrc = 0.                                        "GS002+
      LOOP AT gt_bsid INTO wa_bsid.
        IF wa_bsid-zfbdt <> 0.
          MOVE wa_bsid-zfbdt        TO l_duedt.
        ELSE.
          MOVE wa_bsid-bldat        TO l_duedt.
        ENDIF.
* -- credit memos with rebzg = 'V' -- calculate due-date like invoice
        IF wa_bsid-shkzg <> gc_shkzg OR
         ( wa_bsid-shkzg =  gc_shkzg AND wa_bsid-rebzg = gc_rebzg ).
* -- add terms-period(zbd3t) OR 2nd-disc-period(zbd2t) OR
* --                            1st-disc-period(zbd1t)
          IF wa_bsid-zbd3t <> 0.
            ADD  wa_bsid-zbd3t        TO l_duedt.
          ELSEIF wa_bsid-zbd2t <> 0.
            ADD  wa_bsid-zbd2t        TO l_duedt.
          ELSEIF wa_bsid-zbd1t <> 0.
            ADD  wa_bsid-zbd1t        TO l_duedt.
          ENDIF.
        ENDIF.
        IF wa_bsid-shkzg = gc_shkzg.
          wa_bsid-dmbtr = wa_bsid-dmbtr * -1.
        ENDIF.
* To calculate the Aging dues according to the period.
        PERFORM sub_accum_aging USING l_duedt.

        CONCATENATE text-027 wa_but000-partner INTO wa_details-agin_summ.
        wa_details-tot_ar = g_arbal.
      ENDLOOP.
      wa_details-hclast = g_hclast.                         "CHG002+
      APPEND wa_details TO gt_details.
      CLEAR wa_details.
* If there are no lower level partner we take the highest level partner
* which is the selection screen partner
    ELSE .
      SELECT bukrs    "Company Code
           kunnr    "Customer Number 1
           bldat    "Document Date in Document
           shkzg    "Debit/Credit Indicator
           dmbtr    "Amount in Local Currency
           zfbdt    "Baseline Date for Due Date Calculation
           zbd1t    "Cash discount days 1
           zbd2t    "Cash discount days 2
           zbd3t    "Net Payment Terms Period
           rebzg    "Number of the Invoice the Transaction Belongs to
    INTO TABLE gt_bsid
    FROM bsid   "Accounting: Secondary Index for Customers
    WHERE bukrs = p_bukrs
    AND   kunnr = p_prtnr.
*    CHECK SY-SUBRC = 0.
      IF sy-subrc = 0.
        LOOP AT gt_bsid INTO wa_bsid.
          IF wa_bsid-zfbdt <> 0.
            MOVE wa_bsid-zfbdt        TO l_duedt.
          ELSE.
            MOVE wa_bsid-bldat        TO l_duedt.
          ENDIF.
* -- credit memos with rebzg = 'V' -- calculate due-date like invoice
          IF wa_bsid-shkzg <> gc_shkzg OR
           ( wa_bsid-shkzg =  gc_shkzg AND wa_bsid-rebzg = gc_rebzg ).
* -- add terms-period(zbd3t) OR 2nd-disc-period(zbd2t) OR
* --                            1st-disc-period(zbd1t)
            IF wa_bsid-zbd3t <> 0.
              ADD  wa_bsid-zbd3t        TO l_duedt.
            ELSEIF wa_bsid-zbd2t <> 0.
              ADD  wa_bsid-zbd2t        TO l_duedt.
            ELSEIF wa_bsid-zbd1t <> 0.
              ADD  wa_bsid-zbd1t        TO l_duedt.
            ENDIF.
          ENDIF.
          IF wa_bsid-shkzg = gc_shkzg.
            wa_bsid-dmbtr = wa_bsid-dmbtr * -1.
          ENDIF.
* To calculate the Aging dues according to the period.
          PERFORM sub_accum_aging USING l_duedt.

          CONCATENATE text-027 wa_but000-partner INTO wa_details-agin_summ.
          wa_details-tot_ar = g_arbal.
        ENDLOOP.
        wa_details-hclast = g_hclast.                       "CHG002+
        APPEND wa_details TO gt_details.
        CLEAR wa_details.

      ENDIF.
    ENDIF.                                                  "GS002+
  ENDIF.

* Begin Of GS002+
  IF gt_details IS INITIAL.
    CONCATENATE text-027 wa_but000-partner INTO wa_details-agin_summ.
    wa_details-hclast = g_hclast.
    APPEND wa_details TO gt_details.
  ENDIF.
*End of GS002+
ENDFORM.                    "sub_get_bsid

*&---------------------------------------------------------------------*
*&      Form  sub_get_arrdays
*&---------------------------------------------------------------------*
*  Subroutine to get the days in arrear.
*----------------------------------------------------------------------*
FORM sub_get_arrdays.
* Begin of change                                     "RN001
  DATA:  l_cuyear(04) TYPE n,
         l_pryear(04) TYPE n.
* End of change                                       "Rn001

* start of addition by PAS01
  CONSTANTS: lc_01 TYPE char2 VALUE '01',
             lc_12 TYPE char2 VALUE '12'.
* end of addition by PAS01

  IF NOT wa_but000 IS INITIAL.

    DATA: lt_knb4   TYPE ukm_t_iknb4,
          wa_knb4   TYPE iknb4,
          l_currmth TYPE char2,
          l_prevmth TYPE char2.

    l_currmth = sy-datum+4(2).
*    l_prevmth = l_currmth - 1.                                        "--PAS01
* start of addition by PAS01
    IF l_currmth = lc_01.
      l_prevmth = lc_12.
    ELSE.
      l_prevmth = l_currmth - 1.
    ENDIF.
* end of addition by PAS01
* Begin of Change                                     "RN001
    l_cuyear = sy-datum+0(4).
    IF l_currmth = '01'.
      l_pryear = l_cuyear - 1.
    ELSE.
      l_pryear = l_cuyear.
    ENDIF.
* End of change                                       "RN001
* Get the payment history for the highest level credit account.
    CALL FUNCTION 'UKM_GET_AR_PAYMENT_HISTORY'
      EXPORTING
        i_bukrs            = p_bukrs
        i_kunnr            = wa_but000-partner
      IMPORTING
        t_knb4             = lt_knb4
      EXCEPTIONS
        no_bukrs           = 1
        no_payment_history = 2
        OTHERS             = 3.
    IF sy-subrc = 0.
*      READ TABLE LT_KNB4 INTO WA_KNB4 WITH KEY MONXX = L_CURRMTH. "RN001
      READ TABLE lt_knb4 INTO wa_knb4 WITH KEY jahxx = l_cuyear"RN001
                                               monxx = l_currmth.
      IF sy-subrc = 0.
* Determine the days in arrear for the current month
        IF wa_knb4-agsxx GT wa_knb4-agnxx.
          g_arrdays = wa_knb4-vzsxx.
        ELSEIF wa_knb4-agnxx GT wa_knb4-agsxx.
          g_arrdays = wa_knb4-vznxx.
        ENDIF.
      ELSE.
* Else determine the days in arrear for the previous month
*        READ TABLE LT_KNB4 INTO WA_KNB4 WITH KEY MONXX = L_PREVMTH."RN001
        READ TABLE lt_knb4 INTO wa_knb4 WITH KEY jahxx = l_pryear"RN001
                                                 monxx = l_prevmth.
        IF sy-subrc = 0.
          IF wa_knb4-agsxx GT wa_knb4-agnxx.
            g_arrdays = wa_knb4-vzsxx.
          ELSEIF wa_knb4-agnxx GT wa_knb4-agsxx.
            g_arrdays = wa_knb4-vznxx.
          ENDIF.
        ENDIF.
      ENDIF.
    ELSE.
      g_arrdays = 0.
    ENDIF.
  ENDIF.
ENDFORM.                    "sub_get_arrdays

