*&---------------------------------------------------------------------*
*&      Form  sub_get_hiacc
*&---------------------------------------------------------------------*
*    Get highest level credit account
*----------------------------------------------------------------------*
FORM sub_get_hiacc.

  DATA: lt_but050 TYPE STANDARD TABLE OF gx_but050 INITIAL SIZE 0,
        wa_but050l TYPE gx_but050.

  SELECT relnr      "BP Relationship Number
         partner1   "Business Partner Number
         partner2   "Business Partner Number
         date_to    "Validity Date (Valid To)
  INTO TABLE gt_but050
  FROM but050    "BP relationships/role definitions: General data
  WHERE partner1 IN g_rpartner
  AND reltyp = gc_ukm001
  AND dftval = g_crdtsgm.

  IF sy-subrc NE 0.                                         "RK09140
    g_hiacc = p_prtnr.                                      "RK09140
  ELSE.                                                     "RK09140

    CLEAR wa_but050.
* Get the highest level credit account.
    READ TABLE gt_but050 INTO wa_but050 WITH KEY
                               partner2 = p_prtnr.
    IF sy-subrc = 0.
      READ TABLE gt_but050 INTO wa_but050 WITH KEY
                      partner2 = wa_but050-partner1.
      IF sy-subrc EQ 0.
* Begin of CHG001-
*        wa_partner-sign = gc_sign.
*        wa_partner-option = gc_option.
*        wa_partner-low = wa_but050-partner2.
*        APPEND wa_partner TO g_rpartner.
*        CLEAR wa_partner.
*end of CHG001-
        READ TABLE gt_but050 INTO wa_but050 WITH KEY
                          partner2 = wa_but050-partner1.
      ENDIF.
* Begin of CHG001-
*      wa_partner-sign = gc_sign.
*      wa_partner-option = gc_option.
*      wa_partner-low = wa_but050-partner1.
*      APPEND wa_partner TO g_rpartner.
*      CLEAR wa_partner.
* End of CHG001-
      g_hiacc = wa_but050-partner1.
    ELSE.
* Begin of CHG001-
*      wa_partner-sign = gc_sign.
*      wa_partner-option = gc_option.
*      wa_partner-low = p_prtnr.
*      APPEND wa_partner TO g_rpartner.
*      CLEAR wa_partner.
* End of CHG001-

* The highest level credit account.
      g_hiacc = p_prtnr.
    ENDIF.

* Beign of CHG001+
* Retrieving the lower level credit accounts.
    lt_but050[] = gt_but050[].
    DELETE lt_but050 WHERE partner1 NE p_prtnr.
    CLEAR wa_but050l.
    LOOP AT lt_but050 INTO wa_but050l.
      wa_partner-sign = gc_sign.
      wa_partner-option = gc_option.
      wa_partner-low = wa_but050l-partner2.
      APPEND wa_partner TO g_rpartner.
      CLEAR wa_partner.

      CLEAR wa_but050.
      READ TABLE gt_but050 INTO wa_but050 WITH KEY
                                 partner1 = wa_but050l-partner2.
      IF sy-subrc = 0.
        READ TABLE gt_but050 INTO wa_but050 WITH KEY
                        partner1 = wa_but050-partner2.
        WHILE sy-subrc EQ 0.
          wa_partner-sign = gc_sign.
          wa_partner-option = gc_option.
          wa_partner-low = wa_but050-partner2.
          APPEND wa_partner TO g_rpartner.
          CLEAR wa_partner.

          READ TABLE gt_but050 INTO wa_but050 WITH KEY
                            partner1 = wa_but050-partner2.
        ENDWHILE.
        wa_partner-sign = gc_sign.
        wa_partner-option = gc_option.
        wa_partner-low = wa_but050-partner2.
        APPEND wa_partner TO g_rpartner.
        CLEAR wa_partner.
      ENDIF.
    ENDLOOP.
* End of CHG001+
  ENDIF.                                                    "RK09140

* Begin of RK09140
  IF g_rpartner[] IS INITIAL.
* If no lower accounts are found, assign the same partner as lowest account
    wa_partner-sign = gc_sign.
    wa_partner-option = gc_option.
    wa_partner-low = p_prtnr.
    APPEND wa_partner TO g_rpartner.
    CLEAR wa_partner.
  ENDIF.
* End of RK09140
ENDFORM.                    "sub_get_hiacc
