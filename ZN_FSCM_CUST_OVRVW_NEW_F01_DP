FORM sub_get_accbal.

  DATA: l_tkeybal TYPE STANDARD TABLE OF bapi3007_3 INITIAL SIZE 0,
        l_return TYPE bapireturn,
        l_keybal TYPE bapi3007_3.

  IF NOT g_rpartner[] IS INITIAL.
