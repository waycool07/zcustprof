*----------------------------------------------------------------------*
FORM sub_get_ukm_cms.
  IF NOT wa_but000 IS INITIAL.
    SELECT SINGLE partner        "Business Partner Number
           check_rule     "Rule for Credit Check
           risk_class     "Risk Class
    INTO wa_ukm_cms
    FROM ukmbp_cms   "SAP Credit Management: Credit Master Data for Partner
    WHERE partner = wa_but000-partner.
