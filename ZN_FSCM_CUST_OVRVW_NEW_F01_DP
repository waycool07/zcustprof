FORM sub_get_hold2 .

  RANGES: gbstk FOR vbuk-gbstk.
  MOVE 'I'    TO gbstk-sign.
  MOVE 'EQ'   TO gbstk-option.
  MOVE 'A'    TO gbstk-low.
  APPEND gbstk.
  MOVE 'I'    TO gbstk-sign.
  MOVE 'EQ'   TO gbstk-option.
  MOVE 'B'    TO gbstk-low.
  APPEND gbstk.

  SUBMIT zrvkred01_pcec_new
                        WITH knkli IN g_rpartner
                        WITH cmgst EQ 'B'
                        WITH gbstk IN gbstk
                        WITH order EQ 'X'
                        WITH deliv EQ 'X'
                        WITH callmode EQ 'X'
                        WITH code EQ 'VKM1'
                        AND RETURN.

  DATA:  v_on_hold(30) TYPE c.
  GET PARAMETER ID  'HOLD' FIELD v_on_hold.
  CONDENSE v_on_hold.
  g_onhold = v_on_hold.

ENDFORM.                    " sub_get_hold2

