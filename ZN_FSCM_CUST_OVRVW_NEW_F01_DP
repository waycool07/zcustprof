        customer    = p_prtnr
        keydate     = sy-datum
      IMPORTING
        return      = l_return
      TABLES
        keybalance  = l_tkeybal.

    IF l_return IS INITIAL.
      CLEAR l_keybal.
      READ TABLE l_tkeybal INTO l_keybal INDEX 1.
      CHECK sy-subrc = 0.
* Sum up the A/R balances.
      g_arbal = g_arbal + l_keybal-t_curr_bal.
    ENDIF.
  ENDIF.
