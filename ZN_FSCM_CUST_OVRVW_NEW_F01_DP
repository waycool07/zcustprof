*&---------------------------------------------------------------------*
*&      Form  sub_get_ukm_sgm
*&---------------------------------------------------------------------*
* Subroutine to retrieve data from table UKMBP_CMS_SGM
*----------------------------------------------------------------------*
FORM sub_get_ukm_sgm.
  IF NOT wa_but000 IS INITIAL.
    SELECT SINGLE partner    "Business Partner Number
           credit_sgmnt      "Credit Segment
           credit_limit      "Credit Limit
           limit_valid_date  "Valid to date
           follow_up_dt      "Resubmission Date
    INTO wa_ukm_sgm
    FROM ukmbp_cms_sgm  "SAP Credit Management: Master Data for Credit Account
    WHERE partner = wa_but000-partner
    AND   credit_sgmnt = g_crdtsgm.
* Sy-subrc check does not effect further processing hence not required.
  ENDIF.
ENDFORM.                    "sub_get_ukm_sgm

