*&---------------------------------------------------------------------*
*&      Form  SUB_get_hold1
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM sub_get_hold1 .
  DATA:   lv_onhold TYPE netwr_ap.

  CLEAR g_onhold.

  IF NOT g_rpartner[] IS INITIAL.
    SELECT vbeln   "Sales Document
           knkli   "Customer's account number with credit limit reference

    INTO TABLE gt_vbak
    FROM vbak      "Sales Document: Header Data
    WHERE vbeln IN g_rvbeln
    AND knkli IN g_rpartner.
  ENDIF.

  IF NOT gt_vbak[] IS INITIAL.
    LOOP AT gt_vbak INTO wa_vbak.
      PERFORM upload_table.
      CALL FUNCTION 'SD_CREDIT_VALUE_ORDER'
        EXPORTING
          vbak   = xvbak
        IMPORTING
          amtbl  = xvbkred-kwkkb
          kwkkg  = xvbkred-kwkkf
        TABLES
          xvbap  = xvbap
          xvbapf = xvbapf
          xvbfa  = xvbfa
          xvbkd  = xvbkd
          xvbup  = xvbup.
      CLEAR lv_onhold.
      MOVE xvbkred-kwkkb TO lv_onhold .
      g_onhold = lv_onhold + g_onhold.
    ENDLOOP.
  ENDIF.

ENDFORM.                    " SUB_get_hold1
