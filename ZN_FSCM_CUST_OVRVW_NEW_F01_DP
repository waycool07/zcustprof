*&---------------------------------------------------------------------*
*&      Form  SUB_ACCUM_AGING
*&---------------------------------------------------------------------*
*  Subroutine to accumulate the aging summary details                  *
*----------------------------------------------------------------------*

FORM sub_accum_aging USING p_duedt TYPE bldat.

  DATA: l_today TYPE sy-datum,
         l_days_diff TYPE i.

  l_today = sy-datum.

* Accumulate the aging data for all the lower level accounts
  l_days_diff = l_today - p_duedt.

  ADD wa_bsid-dmbtr             TO wa_details-tot_ar.
  IF l_days_diff < 1.
    ADD wa_bsid-dmbtr          TO wa_details-not_due.

  ELSEIF l_days_diff < 31.
    ADD wa_bsid-dmbtr           TO wa_details-1_30ds.

  ELSEIF l_days_diff < 61.
    ADD wa_bsid-dmbtr          TO wa_details-31_60ds.

  ELSEIF l_days_diff < 91.
    ADD wa_bsid-dmbtr          TO wa_details-61_90ds.

  ELSEIF l_days_diff > 90.
*   ELSE.
    ADD wa_bsid-dmbtr          TO wa_details-over90.

  ENDIF.

  wa_details-tpd = wa_details-1_30ds + wa_details-31_60ds +
                   wa_details-61_90ds + wa_details-over90.

ENDFORM.                    " SUB_ACCUM_AGING

