        postab-zorderval = postab-zorderval + ( <gt_vbap>-netwr + <gt_vbap>-mwsbp ).   "order value

        READ TABLE gt_vbfa ASSIGNING <gt_vbfa> WITH KEY vbelv = <gt_vbap>-vbeln
                                                        posnv = <gt_vbap>-posnr BINARY SEARCH.

        IF sy-subrc = 0.

          IF <gt_vbap>-kwmeng <> 0 AND <gt_vbap>-kwmeng <> <gt_vbfa>-rfmng.
            v_netpr = ABS( ( <gt_vbap>-netwr + <gt_vbap>-mwsbp ) / <gt_vbap>-kwmeng ).
            v_netwr = v_netpr * <gt_vbfa>-rfmng.
          ELSE.
            v_netwr = <gt_vbap>-netwr + <gt_vbap>-mwsbp.
          ENDIF.

          IF <gt_vbfa>-vbtyp_n = 'H'.
            postab-zorderval = postab-zorderval - v_netwr.   "order value return  "YG09157 2008.08.20
          ENDIF.
        ENDIF.
