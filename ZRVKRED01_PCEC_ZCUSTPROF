        postab-knkli = wa_knkli-knkli.
        MODIFY postab TRANSPORTING knkli.
* Populating Risk class.
        CLEAR wa_ukm_cms.
        READ TABLE gt_ukm_cms INTO wa_ukm_cms WITH KEY partner = wa_knkli-knkli
        BINARY SEARCH.
        IF sy-subrc = 0.
          postab-ctlpc = wa_ukm_cms-risk_class.
          MODIFY postab TRANSPORTING ctlpc.
        ENDIF.

* Polpulating Credit limit and Open Credit Limit
        CLEAR wa_ukm_sgm.
        READ TABLE gt_ukm_sgm INTO wa_ukm_sgm WITH KEY partner = wa_knkli-knkli
        BINARY SEARCH.
        IF sy-subrc = 0.
          postab-zz_klimk = wa_ukm_sgm-credit_limit.
          MODIFY postab TRANSPORTING zz_klimk.
* get the open order amount
          CALL FUNCTION 'UKM_COMMTS_READ'
            EXPORTING
              i_partner     = wa_ukm_sgm-partner
              i_segment     = wa_ukm_sgm-credit_sgmnt
            TABLES
              et_ukm_totals = gt_ukm_totals.
          IF sy-subrc = 0.
            CLEAR: wa_ukm_totals.
            LOOP AT gt_ukm_totals INTO wa_ukm_totals.
* Calculate the total credit exposure
              g_totexp = g_totexp + wa_ukm_totals-amount.
            ENDLOOP.
* Calculate the open credit limit
            postab-zz_opn_klimk = wa_ukm_sgm-credit_limit - g_totexp.
            MODIFY postab TRANSPORTING zz_opn_klimk.
            CLEAR g_totexp.
          ENDIF.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.
