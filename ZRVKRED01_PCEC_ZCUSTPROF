  IF NOT postab[] IS INITIAL.
* Retrieve the credit account from VBAK
    SELECT vbeln netwr knkli
    FROM vbak
    INTO TABLE gt_knkli
    FOR ALL ENTRIES IN postab
    WHERE vbeln = postab-vbeln.
    IF sy-subrc = 0.
      gt_odrval[] = gt_knkli[].
      SORT gt_odrval BY vbeln.
    ENDIF.
* Retrieve the credit account from LIKP
    SELECT vbeln knkli ternr xblnr
    FROM likp
    INTO TABLE gt_likp
    FOR ALL ENTRIES IN postab
    WHERE vbeln = postab-vbeln.
    IF sy-subrc = 0.
      SORT gt_likp BY vbeln.
      SORT gt_knkli BY vbeln.
      CLEAR wa_likp.
      LOOP AT gt_likp INTO wa_likp.
        CLEAR wa_knkli.
        READ TABLE gt_knkli INTO wa_knkli WITH KEY vbeln = wa_likp-vbeln
        BINARY SEARCH.
        IF sy-subrc NE 0 OR wa_knkli-knkli IS INITIAL.
          wa_knkli-vbeln = wa_likp-vbeln.
          wa_knkli-knkli = wa_likp-knkli.
          APPEND wa_knkli TO gt_knkli.
          CLEAR wa_knkli.
        ENDIF.
      ENDLOOP.
    ENDIF.
* Begin of CHG004+
    IF NOT gt_likp[] IS INITIAL.
* Retrieve data from SD document: Delivery: Item data (LIPS)
      SELECT vbeln posnr vgbel netwr
      FROM lips
      INTO TABLE gt_lips
      FOR ALL ENTRIES IN gt_likp
      WHERE vbeln = gt_likp-vbeln.
      IF sy-subrc = 0.
        SORT gt_lips BY vbeln.
* Retrieve data from Sales Document: Business Data (VBKD)
        SELECT vbeln posnr zterm
        FROM vbkd
        INTO TABLE gt_vbkd
        FOR ALL ENTRIES IN gt_lips
        WHERE vbeln = gt_lips-vgbel.
        IF sy-subrc = 0.
          SORT gt_vbkd BY vbeln.
        ENDIF.
* calculate net sum.
        LOOP AT gt_lips INTO wa_lips.
          AT END OF vbeln.
            SUM.
            APPEND wa_lips TO gt_netsum.
            CLEAR wa_lips.
          ENDAT.
        ENDLOOP.
      ENDIF.

      gt_likptmp[] = gt_likp[].
      DELETE ADJACENT DUPLICATES FROM gt_likptmp COMPARING xblnr.
* Retrieve delivery data from Sales Document: Header Data
      SELECT vbeln bstnk aufnr
      FROM vbak
      INTO TABLE gt_pordr
      FOR ALL ENTRIES IN gt_likptmp
      WHERE vbeln = gt_likptmp-xblnr+0(10).
      IF sy-subrc = 0.
        SORT gt_pordr BY vbeln.
      ENDIF.
    ENDIF.

* Populate the range for all the orders and delivery documents
    CLEAR: wa_knkli.
    LOOP AT gt_knkli INTO wa_knkli.
      CLEAR wa_odrval.
      READ TABLE gt_odrval INTO wa_odrval WITH KEY vbeln  = wa_knkli-vbeln
      BINARY SEARCH.
      IF sy-subrc = 0.
        wa_vbrng-sign = 'I'.
        wa_vbrng-option = 'EQ'.
        wa_vbrng-low = wa_odrval-vbeln.
        APPEND wa_vbrng TO gt_vbrng.
        CLEAR wa_vbrng.
      ENDIF.
      CLEAR wa_likp.
      READ TABLE gt_likp INTO wa_likp WITH KEY vbeln = wa_knkli-vbeln
      BINARY SEARCH.
      IF sy-subrc = 0.
        wa_vbrng-sign = 'I'.
        wa_vbrng-option = 'EQ'.
        wa_vbrng-low = wa_likp-xblnr+0(10).
        APPEND wa_vbrng TO gt_vbrng.
        CLEAR wa_vbrng.
      ENDIF.
    ENDLOOP.

    IF NOT gt_vbrng IS INITIAL.
* Retrieve data from Sales Document: Item Data
      SELECT vbeln posnr netwr kwmeng mwsbp                        "YG09157 2008.08.28   kwmeng: total order item qty
      FROM vbap
      INTO TABLE gt_vbap
      WHERE vbeln IN gt_vbrng
        AND abgru = space.                                          "YG09157 2008.08.20

      IF sy-subrc = 0.
        SORT gt_vbap BY vbeln posnr.
* Retrieve data from Sales Document Flow
        SELECT vbelv posnv vbtyp_n vbeln rfmng                      "YG09157 2008.08.28   rfmng
        FROM vbfa
        INTO TABLE gt_vbfa
        FOR ALL ENTRIES IN gt_vbap
        WHERE vbelv = gt_vbap-vbeln
        AND   posnv = gt_vbap-posnr
        AND ( vbtyp_n = gc_vbtyp_j OR vbtyp_n EQ 'M' or vbtyp_n EQ 'H' ).   "YG09157 2008.08.20

        IF sy-subrc = 0.

          SORT gt_vbfa BY vbelv posnv.
          CLEAR wa_vbfa.

          LOOP AT gt_vbfa INTO wa_vbfa.

            on change of wa_vbfa-vbelv or wa_vbfa-posnv.    "SP001

              CLEAR wa_vbap.

              READ TABLE gt_vbap INTO wa_vbap WITH KEY vbeln = wa_vbfa-vbelv
                                                       posnr = wa_vbfa-posnv BINARY SEARCH.
              IF sy-subrc = 0.
                IF wa_vbfa-vbtyp_n = gc_vbtyp_j.
                  g_netval = g_netval + wa_vbap-netwr.
                ELSE.
                  g_netval = g_netval - wa_vbap-netwr.       "YG09157 2008.08.20  delivery return
                ENDIF.
              ENDIF.
            endon.                                          "SP001

            AT END OF vbelv.
              wa_netval-vbeln = wa_vbfa-vbelv.
              wa_netval-value = g_netval.
              APPEND wa_netval TO gt_netval.
              CLEAR: wa_netval, g_netval.
            ENDAT.

          ENDLOOP.

          SORT gt_netval BY vbeln.
        ENDIF.

      ENDIF.
    ENDIF.

* End of CHG004+

    IF NOT gt_knkli[] IS INITIAL.
      SORT gt_knkli BY vbeln.
* Get the partner numbers
      SELECT relnr      "BP Relationship Number
       partner1   "Business Partner Number
       partner2   "Business Partner Number
       date_to    "Validity Date (Valid To)
INTO TABLE gt_but050
FROM but050    "BP relationships/role definitions: General data
WHERE reltyp = gc_ukm001.
      IF sy-subrc EQ 0.
        CLEAR wa_knkli.
        LOOP AT gt_knkli INTO wa_knkli.
          CLEAR wa_but050.
* Get the highest level credit account.
          READ TABLE gt_but050 INTO wa_but050 WITH KEY
                                     partner2 = wa_knkli-knkli.
          IF sy-subrc = 0.
            READ TABLE gt_but050 INTO wa_but050 WITH KEY
                            partner2 = wa_but050-partner1.
            WHILE sy-subrc EQ 0.
              READ TABLE gt_but050 INTO wa_but050 WITH KEY
                                 partner2 = wa_but050-partner1.
            ENDWHILE.
            wa_knkli-knkli = wa_but050-partner1.
            MODIFY gt_knkli FROM wa_knkli  TRANSPORTING knkli.
          ENDIF.
        ENDLOOP.
      ENDIF.
    ENDIF.

* retrieve the risk class.
    SELECT partner
           risk_class
    FROM ukmbp_cms
    INTO TABLE gt_ukm_cms
    FOR ALL ENTRIES IN gt_knkli
    WHERE partner = gt_knkli-knkli.
    IF sy-subrc = 0.
      SORT gt_ukm_cms BY partner.
* Retrieve the Risk Class text
