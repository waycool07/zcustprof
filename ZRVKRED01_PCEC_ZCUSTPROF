      ENDIF.

*Populating the delivery value and order value:
* YG09157 2008.07.30 begin

      FIELD-SYMBOLS: <gt_vbfa> LIKE LINE OF gt_vbfa,
                     <gt_vbap> LIKE LINE OF gt_vbap.

      DATA: v_delivery_doc(1) TYPE c,
            v_netpr TYPE netpr,         "YG09157 2008.08.28
            v_netwr TYPE netwr.

      CLEAR: v_delivery_doc,
             postab-zorderval,
             postab-kzwi3.


      LOOP AT gt_vbfa ASSIGNING <gt_vbfa> WHERE vbeln = postab-vbeln      "delivery doc
                                            AND vbelv = postab-zvbeln2.   "order#

        READ TABLE gt_vbap ASSIGNING <gt_vbap> WITH KEY vbeln = <gt_vbfa>-vbelv
                                                        posnr = <gt_vbfa>-posnv
                                                        BINARY SEARCH.
        IF sy-subrc = 0.

          CLEAR: v_netpr,  v_netwr.

          IF <gt_vbap>-kwmeng <> 0 AND <gt_vbap>-kwmeng <> <gt_vbfa>-rfmng.
            v_netpr = ABS( ( <gt_vbap>-netwr + <gt_vbap>-mwsbp ) / <gt_vbap>-kwmeng ).
            v_netwr = v_netpr * <gt_vbfa>-rfmng.
          ELSE.
            v_netwr = <gt_vbap>-netwr + <gt_vbap>-mwsbp.
          ENDIF.

          IF <gt_vbfa>-vbtyp_n = gc_vbtyp_j.
            postab-kzwi3     = postab-kzwi3  + v_netwr.   "delivery value     "YG09157 2008.08.28
          ELSEIF <gt_vbfa>-vbtyp_n = 'M'.
            select single * from vbrk where vbeln = <gt_vbfa>-vbeln."SP001
            IF vbrk-fksto <> 'X'.                           "SP001
              postab-kzwi3     = postab-kzwi3  - v_netwr.
            ENDIF.                                          "SP001

          ENDIF.
        ENDIF.

        v_delivery_doc = 'X'.

      ENDLOOP.
